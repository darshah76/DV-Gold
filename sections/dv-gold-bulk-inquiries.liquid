{% liquid
  assign section_anchor = 'dv-gold-bulk-inquiries-' | append: section.id
  assign whatsapp_number = section.settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' | remove: '(' | remove: ')' | remove: '.'
  assign whatsapp_message = section.settings.whatsapp_message
  assign whatsapp_href = '#'
  if whatsapp_number != blank
    assign whatsapp_href = 'https://wa.me/' | append: whatsapp_number
    if whatsapp_message != blank
      assign encoded_message = whatsapp_message | url_encode
      assign whatsapp_href = whatsapp_href | append: '?text=' | append: encoded_message
    endif
  endif
%}

<section
  id="{{ section_anchor }}"
  class="dv-bulk-inquiries dv-content-section color-{{ section.settings.color_scheme }}"
  style="
    --dv-bulk-bg: {{ section.settings.background_color }};
    --dv-bulk-card-bg: {{ section.settings.card_background }};
    --dv-bulk-card-border: {{ section.settings.card_border_color }};
    --dv-bulk-heading: {{ section.settings.heading_color }};
    --dv-bulk-icon: {{ section.settings.icon_color }};
    --dv-bulk-text: {{ section.settings.text_color }};
    --dv-bulk-button-bg: {{ section.settings.button_background }};
    --dv-bulk-button-text: {{ section.settings.button_text_color }};
    --dv-bulk-max-width: {{ section.settings.max_width }}px;
    --dv-bulk-mobile-padding-top: {{ section.settings.mobile_padding_top }}px;
    --dv-bulk-mobile-padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    --dv-bulk-desktop-padding-top: {{ section.settings.desktop_padding_top }}px;
    --dv-bulk-desktop-padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
  "
>
  <div class="dv-bulk-inquiries__inner dv-section-container">
    <div class="dv-bulk-inquiries__card">
      <div class="dv-bulk-inquiries__content">
        <div class="dv-bulk-inquiries__graphic" aria-hidden="true">
          <svg viewBox="0 0 96 76" focusable="false">
            <path d="M8 8h52v36H25L8 60V8Z" fill="none" stroke="currentColor" stroke-width="6" stroke-linejoin="round"/>
            <path d="M61 23h14v36L58 44h3V23Z" fill="currentColor"/>
            <path d="M60 23h14v36L58 44h2V23Z" fill="none" stroke="currentColor" stroke-width="6" stroke-linejoin="round"/>
          </svg>
        </div>

        {% if section.settings.heading != blank %}
          <h2 class="dv-bulk-inquiries__heading">
            {% assign heading_words = section.settings.heading | split: ' ' %}
            {% for word in heading_words %}
              <span>{{ word }}</span>
            {% endfor %}
          </h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="dv-bulk-inquiries__text rte">{{ section.settings.text }}</div>
        {% endif %}
      </div>

      {% if section.settings.button_label != blank %}
        <div class="dv-bulk-inquiries__button-wrapper whatsapp-button-wrapper">
          <a
            class="dv-bulk-inquiries__button whatsapp-button{% if whatsapp_number == blank %} dv-bulk-inquiries__button--disabled{% endif %}"
            href="{{ whatsapp_href }}"
            {% if whatsapp_number == blank %}
              role="link"
              aria-disabled="true"
              tabindex="-1"
            {% else %}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="{{ section.settings.button_label | escape }}"
            {% endif %}
          >
            <svg
              class="dv-bulk-inquiries__button-icon"
              viewBox="0 0 20 20"
              xmlns="http://www.w3.org/2000/svg"
              focusable="false"
              aria-hidden="true"
            >
              {% render 'icon', icon: 'whatsapp' %}
            </svg>
            <span>{{ section.settings.button_label }}</span>
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  {% render 'dv-gold-home-typography', section_anchor: section_anchor %}
  #{{ section_anchor }} {
    background: var(--dv-bulk-bg);
    color: var(--dv-bulk-text);
    padding-block: 0;
  }

  #{{ section_anchor }} .dv-bulk-inquiries__inner {
    width: min(calc(100% - clamp(48px, 10vw, 96px)), var(--dv-bulk-max-width));
    margin-inline: auto;
  }

  #{{ section_anchor }} .dv-bulk-inquiries__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 0;
    min-height: clamp(456px, 103.6vw, 484px);
    padding: clamp(56px, 12.4vw, 58px) clamp(28px, 7vw, 86px) clamp(58px, 12.8vw, 60px);
    padding-inline: clamp(28px, 7vw, 86px);
    overflow: visible;
    border: 1px solid var(--dv-bulk-card-border);
    border-radius: 28px;
    background: var(--dv-bulk-card-bg);
    box-shadow: none;
  }

  #{{ section_anchor }} .dv-bulk-inquiries__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: min(100%, 860px);
    text-align: center;
  }

  #{{ section_anchor }} .dv-bulk-inquiries__graphic {
    width: clamp(76px, 18.9vw, 88px);
    height: clamp(61px, 15vw, 70px);
    margin-bottom: clamp(25px, 5.8vw, 27px);
    color: var(--dv-bulk-icon);
  }

  #{{ section_anchor }} .dv-bulk-inquiries__graphic svg {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  #{{ section_anchor }} .dv-bulk-inquiries__heading {
    display: block;
    width: 100%;
    max-width: min(100%, 720px);
    margin: 0 auto 30px;
    margin-inline: auto;
    color: var(--dv-bulk-heading);
    font-family: "Playfair Display", var(--font-heading--family), serif;
    font-size: var(--dv-section-heading-size);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: 0;
    text-align: center;
    text-wrap: balance;
    word-break: normal;
    overflow-wrap: normal;
    hyphens: none;
    white-space: normal;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .dv-bulk-inquiries__heading span {
    display: block;
  }

  #{{ section_anchor }} .dv-bulk-inquiries__text {
    color: var(--dv-bulk-text);
    max-width: 100%;
    font-size: clamp(1.65rem, 4.25vw, 1.95rem);
    font-weight: 500;
    line-height: 1.45;
  }

  #{{ section_anchor }} .dv-bulk-inquiries__text p {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    margin: 0;
  }

  #{{ section_anchor }} .dv-bulk-inquiries__text p::before {
    content: "";
    display: inline-block;
    width: 17px;
    height: 17px;
    flex: 0 0 17px;
    background-color: var(--dv-bulk-icon);
    -webkit-mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath fill='black' d='M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.3-.3.75-.4 1.14-.27 1.25.41 2.6.63 3.95.63.61 0 1.1.49 1.1 1.1v3.48c0 .61-.49 1.1-1.1 1.1C10.56 21.72 2.5 13.66 2.5 3.72c0-.61.49-1.1 1.1-1.1h3.5c.61 0 1.1.49 1.1 1.1 0 1.37.22 2.7.63 3.96.12.38.03.82-.28 1.13l-1.93 1.98Zm.52 8.79c.44 0 .8-.36.8-.8s-.36-.8-.8-.8-.8.36-.8.8.36.8.8.8Zm-2.64-2.7c.35 0 .64-.29.64-.64s-.29-.64-.64-.64-.64.29-.64.64.29.64.64.64Zm13.08-9.9c.44 0 .8-.36.8-.8s-.36-.8-.8-.8-.8.36-.8.8.36.8.8.8Zm-2.64-2.7c.35 0 .64-.29.64-.64S15.29 3 14.94 3s-.64.29-.64.64.29.64.64.64Z'/%3E%3C/svg%3E") center / contain no-repeat;
    mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath fill='black' d='M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.3-.3.75-.4 1.14-.27 1.25.41 2.6.63 3.95.63.61 0 1.1.49 1.1 1.1v3.48c0 .61-.49 1.1-1.1 1.1C10.56 21.72 2.5 13.66 2.5 3.72c0-.61.49-1.1 1.1-1.1h3.5c.61 0 1.1.49 1.1 1.1 0 1.37.22 2.7.63 3.96.12.38.03.82-.28 1.13l-1.93 1.98Zm.52 8.79c.44 0 .8-.36.8-.8s-.36-.8-.8-.8-.8.36-.8.8.36.8.8.8Zm-2.64-2.7c.35 0 .64-.29.64-.64s-.29-.64-.64-.64-.64.29-.64.64.29.64.64.64Zm13.08-9.9c.44 0 .8-.36.8-.8s-.36-.8-.8-.8-.8.36-.8.8.36.8.8.8Zm-2.64-2.7c.35 0 .64-.29.64-.64S15.29 3 14.94 3s-.64.29-.64.64.29.64.64.64Z'/%3E%3C/svg%3E") center / contain no-repeat;
  }

  #{{ section_anchor }} .dv-bulk-inquiries__button-wrapper {
    display: flex;
    justify-content: center;
    width: 100%;
    margin-top: clamp(38px, 9vw, 42px);
    overflow: visible;
  }

  #{{ section_anchor }} .dv-bulk-inquiries__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    box-sizing: border-box;
    width: auto;
    max-width: 100%;
    min-height: clamp(66px, 15.85vw, 74px);
    margin: 0;
    padding: 16px 28px;
    border-radius: 8px;
    background: var(--dv-bulk-button-bg);
    color: var(--dv-bulk-button-text);
    font-family: "Manrope", var(--font-body--family), sans-serif;
    font-size: clamp(17px, 1.6vw, 22px);
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    overflow: visible;
    transition: box-shadow 180ms ease, opacity 180ms ease;
    box-shadow: 0 17px 26px rgba(74, 42, 20, 0.11);
  }

  #{{ section_anchor }} .dv-bulk-inquiries__button:hover,
  #{{ section_anchor }} .dv-bulk-inquiries__button:focus-visible {
    box-shadow: 0 20px 32px rgba(74, 42, 20, 0.15);
  }

  #{{ section_anchor }} .dv-bulk-inquiries__button--disabled {
    cursor: not-allowed;
    opacity: 0.55;
    pointer-events: none;
  }

  #{{ section_anchor }} .dv-bulk-inquiries__button-icon {
    display: block;
    width: clamp(22px, 5.5vw, 28px);
    height: clamp(22px, 5.5vw, 28px);
    flex: 0 0 auto;
    overflow: visible;
  }

  @media screen and (min-width: 750px) {
    #{{ section_anchor }} {
      padding-block: 0;
    }

    #{{ section_anchor }} .dv-bulk-inquiries__inner {
      width: min(calc(100% - 64px), var(--dv-bulk-max-width));
    }

    #{{ section_anchor }} .dv-bulk-inquiries__card {
      min-height: auto;
      padding-block: 0;
      padding-inline: clamp(28px, 7vw, 86px);
    }

    #{{ section_anchor }} .dv-bulk-inquiries__heading {
      max-width: min(100%, 760px);
      font-size: var(--dv-section-heading-size);
      letter-spacing: 0;
    }

    #{{ section_anchor }} .dv-bulk-inquiries__button {
      flex: 0 0 auto;
    }
  }
</style>

{% schema %}
{
  "name": "DV Gold bulk inquiries",
  "tag": "section",
  "class": "section-dv-gold-bulk-inquiries",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Bulk Inquiries" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>For B2B &amp; wholesale partnerships</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Chat on WhatsApp" },
    { "type": "text", "id": "whatsapp_number", "label": "WhatsApp number", "default": "919876543210" },
    { "type": "text", "id": "whatsapp_message", "label": "WhatsApp message", "default": "Hello, I would like to inquire about bulk orders." },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#fbf5ef" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#fbf0df" },
    { "type": "color", "id": "card_border_color", "label": "Card border color", "default": "#f0dfbf" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#191512" },
    { "type": "color", "id": "icon_color", "label": "Icon color", "default": "#c99700" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#191512" },
    { "type": "color", "id": "button_background", "label": "Button background", "default": "#25d366" },
    { "type": "color", "id": "button_text_color", "label": "Button text color", "default": "#ffffff" },
    { "type": "range", "id": "max_width", "min": 360, "max": 1400, "step": 20, "unit": "px", "label": "Maximum width", "default": 760 },
    { "type": "range", "id": "mobile_padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Mobile padding top", "default": 108 },
    { "type": "range", "id": "mobile_padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Mobile padding bottom", "default": 76 },
    { "type": "range", "id": "desktop_padding_top", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Desktop padding top", "default": 72 },
    { "type": "range", "id": "desktop_padding_bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Desktop padding bottom", "default": 72 }
  ],
  "presets": [
    { "name": "DV Gold bulk inquiries" }
  ]
}
{% endschema %}
