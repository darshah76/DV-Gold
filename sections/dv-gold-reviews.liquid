{% liquid
  assign section_anchor = 'dv-gold-reviews-' | append: section.id
%}

<section
  id="{{ section_anchor }}"
  class="dv-reviews color-{{ section.settings.color_scheme }}"
  style="
    --dv-reviews-bg: {{ section.settings.background_color }};
    --dv-reviews-card-bg: {{ section.settings.card_background }};
    --dv-reviews-border: {{ section.settings.border_color }};
    --dv-reviews-heading: {{ section.settings.heading_color }};
    --dv-reviews-text: {{ section.settings.text_color }};
    --dv-reviews-muted: {{ section.settings.muted_text_color }};
    --dv-reviews-star: {{ section.settings.star_color }};
    --dv-reviews-max-width: {{ section.settings.max_width }}px;
    --dv-reviews-padding-top-mobile: {{ section.settings.mobile_padding_top }}px;
    --dv-reviews-padding-bottom-mobile: {{ section.settings.mobile_padding_bottom }}px;
    --dv-reviews-padding-top-desktop: {{ section.settings.desktop_padding_top }}px;
    --dv-reviews-padding-bottom-desktop: {{ section.settings.desktop_padding_bottom }}px;
  "
  data-dv-reviews
>
  <div class="dv-reviews__inner">
    <h2 class="dv-reviews__heading">{{ section.settings.heading | escape }}</h2>

    <div class="dv-reviews__summary">
      <div>
        <p class="dv-reviews__rating">{{ section.settings.rating | escape }}</p>
        <div class="dv-reviews__stars" aria-label="{{ section.settings.rating | escape }} out of 5 stars">★★★★★</div>
        <p class="dv-reviews__count">{{ section.settings.review_count_text | escape }}</p>
      </div>

      <button class="dv-reviews__write" type="button" data-review-modal-open>
        {{ section.settings.write_review_label | escape }}
      </button>
    </div>

    <div class="dv-reviews__cards" data-review-pages>
      {% for block in section.blocks %}
        <article class="dv-reviews__card" data-review-card data-page="{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="dv-reviews__card-stars" aria-label="5 out of 5 stars">★★★★★</div>
          <p class="dv-reviews__quote">"{{ block.settings.quote | escape }}"</p>
          <div class="dv-reviews__author-row">
            <p class="dv-reviews__author">{{ block.settings.author | escape }}</p>
            {% if block.settings.verified_label != blank %}
              <p class="dv-reviews__verified" aria-label="{{ block.settings.verified_label | escape }}">
                <span aria-hidden="true">⊙</span> {{ block.settings.verified_label | escape }}
              </p>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>

    <nav class="dv-reviews__pagination" aria-label="Reviews pagination">
      <button class="dv-reviews__page dv-reviews__page--arrow" type="button" aria-label="Previous reviews page" data-review-page-prev>‹</button>
      <button class="dv-reviews__page is-active" type="button" data-review-page-button data-page="1" aria-current="page">1</button>
      <button class="dv-reviews__page" type="button" data-review-page-button data-page="2">2</button>
      <button class="dv-reviews__page" type="button" data-review-page-button data-page="3">3</button>
      <span class="dv-reviews__ellipsis" aria-hidden="true">...</span>
      <button class="dv-reviews__page" type="button" data-review-page-button data-page="25">25</button>
      <button class="dv-reviews__page dv-reviews__page--arrow" type="button" aria-label="Next reviews page" data-review-page-next>›</button>
    </nav>
  </div>

  <div class="dv-reviews__modal" data-review-modal hidden>
    <div class="dv-reviews__modal-backdrop" data-review-modal-close></div>
    <div class="dv-reviews__dialog" role="dialog" aria-modal="true" aria-labelledby="{{ section_anchor }}-modal-title" tabindex="-1">
      <button class="dv-reviews__modal-close" type="button" aria-label="Close review form" data-review-modal-close>×</button>
      <h3 id="{{ section_anchor }}-modal-title" class="dv-reviews__modal-title">Write a Review</h3>
      <form class="dv-reviews__form" data-review-form>
        <label>
          Name
          <input type="text" name="name" autocomplete="name" required>
        </label>
        <label>
          Rating
          <select name="rating" required>
            <option value="5">★★★★★</option>
            <option value="4">★★★★☆</option>
            <option value="3">★★★☆☆</option>
            <option value="2">★★☆☆☆</option>
            <option value="1">★☆☆☆☆</option>
          </select>
        </label>
        <label>
          Review
          <textarea name="review" rows="5" required></textarea>
        </label>
        <button class="dv-reviews__submit" type="submit">Submit Review</button>
        <p class="dv-reviews__success" data-review-success hidden>Thank you! Your review has been received.</p>
      </form>
    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.getElementById({{ section_anchor | json }});
    if (!section || section.dataset.initialized === 'true') return;
    section.dataset.initialized = 'true';

    const cards = [...section.querySelectorAll('[data-review-card]')];
    const pageButtons = [...section.querySelectorAll('[data-review-page-button]')];
    const prevButton = section.querySelector('[data-review-page-prev]');
    const nextButton = section.querySelector('[data-review-page-next]');
    const modal = section.querySelector('[data-review-modal]');
    const dialog = section.querySelector('.dv-reviews__dialog');
    const openButton = section.querySelector('[data-review-modal-open]');
    const closeButtons = [...section.querySelectorAll('[data-review-modal-close]')];
    const form = section.querySelector('[data-review-form]');
    const success = section.querySelector('[data-review-success]');
    const visiblePages = pageButtons.map((button) => Number(button.dataset.page));
    let currentPage = 1;

    const setPage = (page) => {
      const maxPage = Math.max(...visiblePages);
      currentPage = Math.min(Math.max(page, 1), maxPage);
      cards.forEach((card, index) => {
        const fallbackPage = (index % 3) + 1;
        const cardPage = Number(card.dataset.page) || fallbackPage;
        card.hidden = visiblePages.includes(currentPage) && currentPage <= 3 ? cardPage !== currentPage : false;
      });
      pageButtons.forEach((button) => {
        const isActive = Number(button.dataset.page) === currentPage;
        button.classList.toggle('is-active', isActive);
        if (isActive) button.setAttribute('aria-current', 'page');
        else button.removeAttribute('aria-current');
      });
      prevButton.disabled = currentPage === 1;
      nextButton.disabled = currentPage === maxPage;
    };

    pageButtons.forEach((button) => button.addEventListener('click', () => setPage(Number(button.dataset.page))));
    prevButton.addEventListener('click', () => setPage(currentPage - 1));
    nextButton.addEventListener('click', () => setPage(currentPage + 1));

    const openModal = () => {
      modal.hidden = false;
      document.documentElement.classList.add('dv-reviews-modal-open');
      setTimeout(() => dialog.focus(), 0);
    };
    const closeModal = () => {
      modal.hidden = true;
      document.documentElement.classList.remove('dv-reviews-modal-open');
      openButton.focus();
    };

    openButton.addEventListener('click', openModal);
    closeButtons.forEach((button) => button.addEventListener('click', closeModal));
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !modal.hidden) closeModal();
    });
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      success.hidden = false;
      form.reset();
    });

    setPage(1);
  })();
</script>

{% stylesheet %}
  .dv-reviews { background: var(--dv-reviews-bg); color: var(--dv-reviews-text); padding-block: var(--dv-reviews-padding-top-mobile) var(--dv-reviews-padding-bottom-mobile); }
  .dv-reviews__inner { margin-inline: auto; max-width: var(--dv-reviews-max-width); padding-inline: 20px; }
  .dv-reviews__heading { color: var(--dv-reviews-heading); font-family: var(--font-heading--family); font-size: clamp(2.6rem, 7vw, 4.2rem); font-weight: 800; letter-spacing: .12em; line-height: 1.08; margin: 0 0 26px; text-align: center; text-transform: uppercase; }
  .dv-reviews__summary { align-items: center; border-bottom: 1px solid #f2b89a; display: flex; justify-content: space-between; margin-inline: -20px; padding: 0 22px 10px; }
  .dv-reviews__rating { color: #000; font-size: 2.2rem; font-weight: 800; line-height: 1; margin: 0 0 4px; }
  .dv-reviews__stars, .dv-reviews__card-stars { color: var(--dv-reviews-star); letter-spacing: .08em; line-height: 1; }
  .dv-reviews__stars { font-size: 1.5rem; margin-bottom: 4px; }
  .dv-reviews__count { color: var(--dv-reviews-muted); font-size: 1.1rem; margin: 0; }
  .dv-reviews__write { background: #fff8ec; border: 1px solid #f1dfc3; border-radius: 7px; color: #000; cursor: pointer; font-size: 1.2rem; padding: 8px 10px; }
  .dv-reviews__cards { display: grid; gap: 18px; padding-block: 4px 12px; }
  .dv-reviews__card { background: var(--dv-reviews-card-bg); border: 1px solid var(--dv-reviews-border); border-radius: 18px; padding: 24px 23px 22px; }
  .dv-reviews__card-stars { font-size: 1.4rem; margin-bottom: 14px; }
  .dv-reviews__quote { color: #5d5249; font-size: 1.24rem; font-style: italic; line-height: 1.55; margin: 0 0 18px; }
  .dv-reviews__author-row { align-items: center; display: flex; gap: 12px; justify-content: space-between; }
  .dv-reviews__author { color: #2a1712; font-family: var(--font-heading--family); font-size: 1.2rem; font-weight: 800; letter-spacing: .04em; margin: 0; text-transform: uppercase; }
  .dv-reviews__verified { color: var(--dv-reviews-star); font-size: .78rem; font-weight: 800; letter-spacing: .04em; margin: 0; text-transform: uppercase; white-space: nowrap; }
  .dv-reviews__pagination { align-items: center; display: flex; gap: 10px; justify-content: center; }
  .dv-reviews__page { background: transparent; border: 0; color: #2c211b; cursor: pointer; font-size: 1.15rem; padding: 2px; }
  .dv-reviews__page.is-active { font-weight: 800; }
  .dv-reviews__page:disabled { cursor: not-allowed; opacity: .35; }
  .dv-reviews__page--arrow { font-size: 2rem; line-height: .8; }
  .dv-reviews__ellipsis { font-size: 1.1rem; }
  .dv-reviews__modal[hidden] { display: none; }
  .dv-reviews__modal { inset: 0; position: fixed; z-index: 1000; }
  .dv-reviews__modal-backdrop { background: rgba(0, 0, 0, .45); inset: 0; position: absolute; }
  .dv-reviews__dialog { background: #fffaf2; border: 1px solid var(--dv-reviews-border); border-radius: 18px; box-shadow: 0 20px 60px rgba(0, 0, 0, .2); left: 50%; max-width: min(90vw, 440px); padding: 28px; position: absolute; top: 50%; transform: translate(-50%, -50%); width: 100%; }
  .dv-reviews__modal-close { background: transparent; border: 0; cursor: pointer; font-size: 2.8rem; line-height: 1; position: absolute; right: 14px; top: 10px; }
  .dv-reviews__modal-title { color: var(--dv-reviews-heading); font-family: var(--font-heading--family); margin: 0 0 18px; }
  .dv-reviews__form { display: grid; gap: 14px; }
  .dv-reviews__form label { display: grid; font-size: 1.3rem; font-weight: 700; gap: 6px; }
  .dv-reviews__form input, .dv-reviews__form select, .dv-reviews__form textarea { border: 1px solid #e8d3ad; border-radius: 8px; font: inherit; padding: 10px; width: 100%; }
  .dv-reviews__submit { background: var(--dv-reviews-heading); border: 0; border-radius: 999px; color: #fff; cursor: pointer; font-weight: 800; padding: 12px 18px; }
  .dv-reviews__success { color: #2f6f31; font-weight: 700; margin: 0; }
  .dv-reviews-modal-open { overflow: hidden; }
  @media screen and (min-width: 750px) { .dv-reviews { padding-block: var(--dv-reviews-padding-top-desktop) var(--dv-reviews-padding-bottom-desktop); } .dv-reviews__inner { max-width: min(var(--dv-reviews-max-width), 760px); } .dv-reviews__cards { grid-template-columns: repeat(3, minmax(0, 1fr)); } .dv-reviews__summary { margin-inline: 0; } }
{% endstylesheet %}

{% schema %}
{
  "name": "DV Gold reviews",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "WORDS FROM OUR CONNOISSEURS" },
    { "type": "text", "id": "rating", "label": "Rating", "default": "4.86" },
    { "type": "text", "id": "review_count_text", "label": "Review count text", "default": "Based on 76 Reviews" },
    { "type": "text", "id": "write_review_label", "label": "Write review label", "default": "Write a Review" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#fbf5ee" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#fff4e4" },
    { "type": "color", "id": "border_color", "label": "Border", "default": "#f0dfbf" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#9b2d32" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#191512" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text", "default": "#6f665e" },
    { "type": "color", "id": "star_color", "label": "Stars", "default": "#c99700" },
    { "type": "range", "id": "max_width", "min": 280, "max": 1200, "step": 20, "unit": "px", "label": "Max width", "default": 320 },
    { "type": "range", "id": "mobile_padding_top", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Mobile padding top", "default": 42 },
    { "type": "range", "id": "mobile_padding_bottom", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Mobile padding bottom", "default": 36 },
