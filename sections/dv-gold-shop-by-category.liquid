{% liquid
  assign section_anchor = 'dv-gold-shop-by-category-' | append: section.id
%}

<section
  id="{{ section_anchor }}"
  class="dv-category color-{{ section.settings.color_scheme }}"
  style="
    --dv-category-bg: {{ section.settings.background_color }};
    --dv-category-heading: {{ section.settings.heading_color }};
    --dv-category-accent: {{ section.settings.accent_color }};
    --dv-category-card-bg: {{ section.settings.card_background }};
    --dv-category-button-bg: {{ section.settings.button_background }};
    --dv-category-button-text: {{ section.settings.button_text_color }};
    --dv-category-connector-width: {{ section.settings.connector_width }}px;
    --dv-category-connector-height: {{ section.settings.connector_height }}px;
    --dv-category-connector-thickness: {{ section.settings.connector_thickness }}px;
    --dv-category-connector-dash: {{ section.settings.connector_dash_length }}px;
    --dv-category-connector-gap: {{ section.settings.connector_gap_length }}px;
    --dv-category-max-width: {{ section.settings.max_width }}px;
    --dv-category-mobile-padding-top: {{ section.settings.mobile_padding_top }}px;
    --dv-category-mobile-padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    --dv-category-desktop-padding-top: {{ section.settings.desktop_padding_top }}px;
    --dv-category-desktop-padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
  "
>
  <div class="dv-category__inner">
    {% if section.settings.heading != blank %}
      <h2 class="dv-category__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="dv-category__list" role="list">
      {% for block in section.blocks %}
        {% liquid
          assign rotation = block.settings.card_rotation | default: 0
          assign block_card_bg = block.settings.card_background
          if block_card_bg == blank or block_card_bg == 'rgba(0,0,0,0)'
            assign block_card_bg = section.settings.card_background
          endif
        %}

        <div class="dv-category__item" role="listitem" {{ block.shopify_attributes }}>
          <div
            class="dv-category__card-shell"
            style="--dv-category-rotation: {{ rotation }}deg; --dv-category-block-card-bg: {{ block_card_bg }};"
          >
            <a
              class="dv-category__card"
              href="{{ block.settings.link | default: '#' }}"
              {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
              aria-label="{{ block.settings.title | default: block.settings.button_label | escape }}"
            >
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    widths: '320, 480, 640, 800, 1000, 1200',
                    sizes: '(min-width: 990px) 520px, 86vw',
                    class: 'dv-category__image',
                    alt: block.settings.image.alt
                }}
              {% else %}
                <div class="dv-category__placeholder" aria-hidden="true">
                  {{ 'image' | placeholder_svg_tag: 'dv-category__placeholder-svg' }}
                </div>
              {% endif %}

              {% if block.settings.button_label != blank %}
                <span class="dv-category__button">{{ block.settings.button_label }}</span>
              {% endif %}
            </a>
          </div>

          {% if block.settings.title != blank %}
            <h3 class="dv-category__title">{{ block.settings.title }}</h3>
          {% endif %}

          {% unless forloop.last %}
            {% liquid
              assign connector_center = 30
              assign connector_curve = section.settings.connector_curve
              assign connector_right = connector_center | plus: connector_curve
              assign connector_left = connector_center | minus: connector_curve
              assign connector_half_curve = connector_curve | divided_by: 2
              assign connector_soft_right = connector_center | plus: connector_half_curve
              assign connector_soft_left = connector_center | minus: connector_half_curve
            %}
            <svg
              class="dv-category__connector"
              aria-hidden="true"
              focusable="false"
              viewBox="0 0 60 180"
              preserveAspectRatio="none"
            >
              <path
                class="dv-category__connector-path"
                d="M30 0 C {{ connector_right }} 34 {{ connector_left }} 64 30 92 C {{ connector_soft_right }} 116 {{ connector_soft_left }} 142 30 180"
                pathLength="180"
              />
            </svg>
          {% endunless %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #{{ section_anchor }} {
    background: var(--dv-category-bg);
    padding-block: var(--dv-category-mobile-padding-top) var(--dv-category-mobile-padding-bottom);
    overflow: hidden;
  }

  #{{ section_anchor }} .dv-category__inner {
    width: min(100% - 32px, var(--dv-category-max-width));
    margin-inline: auto;
  }

  #{{ section_anchor }} .dv-category__heading {
    margin: 0 0 clamp(46px, 12vw, 92px);
    color: var(--dv-category-heading);
    font-family: var(--font-heading--family);
    font-size: var(--dv-section-heading-size);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    text-align: center;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .dv-category__list {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #{{ section_anchor }} .dv-category__item {
    position: relative;
    width: min(100%, 720px);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #{{ section_anchor }} .dv-category__card-shell {
    width: min(100%, 640px);
    transform: rotate(var(--dv-category-rotation));
    filter: drop-shadow(0 7px 10px rgba(45, 28, 14, 0.13));
  }

  #{{ section_anchor }} .dv-category__card {
    position: relative;
    display: block;
    aspect-ratio: 1.52 / 1;
    padding: clamp(10px, 2vw, 16px);
    background: var(--dv-category-block-card-bg);
    border: 1px solid rgba(255, 255, 255, 0.75);
    border-radius: 2px;
    box-shadow: 0 0 0 1px rgba(117, 87, 45, 0.04), 0 2px 4px rgba(45, 28, 14, 0.08);
    text-decoration: none;
  }

  #{{ section_anchor }} .dv-category__image,
  #{{ section_anchor }} .dv-category__placeholder {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  #{{ section_anchor }} .dv-category__placeholder {
    background: rgba(255, 255, 255, 0.34);
  }

  #{{ section_anchor }} .dv-category__placeholder-svg {
    width: 100%;
    height: 100%;
    opacity: 0.35;
  }

  #{{ section_anchor }} .dv-category__button {
    position: absolute;
    left: 50%;
    bottom: clamp(10px, 2.5vw, 18px);
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 34px;
    padding: 7px 15px 6px;
    border-radius: 7px;
    background: var(--dv-category-button-bg);
    color: var(--dv-category-button-text);
    font-size: clamp(1.3rem, 3vw, 1.7rem);
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
  }

  #{{ section_anchor }} .dv-category__title {
    position: relative;
    z-index: 2;
    margin: clamp(22px, 5vw, 34px) 0 8px;
    padding-inline: 14px;
    background: var(--dv-category-bg);
    color: var(--dv-category-heading);
    font-family: var(--font-heading--family);
    font-size: clamp(2.2rem, 6vw, 3.1rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.18em;
    text-align: center;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .dv-category__title::after {
    content: '';
    display: block;
    width: 86px;
    height: 2px;
    margin: 10px auto 0;
    background: var(--dv-category-accent);
  }

  #{{ section_anchor }} .dv-category__connector {
    position: relative;
    z-index: 1;
    display: block;
    width: var(--dv-category-connector-width);
    height: clamp(118px, 24vw, var(--dv-category-connector-height));
    margin: clamp(-86px, -12vw, -58px) auto clamp(34px, 9vw, 66px);
    overflow: visible;
  }

  #{{ section_anchor }} .dv-category__connector-path {
    fill: none;
    stroke: var(--dv-category-accent);
    stroke-width: var(--dv-category-connector-thickness);
    stroke-linecap: square;
    stroke-dasharray: var(--dv-category-connector-dash) var(--dv-category-connector-gap);
    vector-effect: non-scaling-stroke;
  }

  @media screen and (min-width: 750px) {
    #{{ section_anchor }} {
      padding-block: var(--dv-category-desktop-padding-top) var(--dv-category-desktop-padding-bottom);
    }

    #{{ section_anchor }} .dv-category__inner {
      width: min(100% - 64px, var(--dv-category-max-width));
    }
  }

  @media screen and (min-width: 990px) {
    #{{ section_anchor }} .dv-category__heading {
      text-align: left;
      margin-left: max(0px, calc((var(--dv-category-max-width) - 720px) / 2));
    }
  }
</style>

{% schema %}
{
  "name": "DV Gold shop by category",
  "tag": "section",
  "class": "section-dv-gold-shop-by-category",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "SHOP BY CATEGORY" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#fbf5ee" },
    { "type": "color", "id": "heading_color", "label": "Heading and category text color", "default": "#9b2d32" },
    { "type": "color", "id": "accent_color", "label": "Connector and underline color", "default": "#c89100" },
    { "type": "color", "id": "card_background", "label": "Default card background", "default": "#fbefd9" },
    { "type": "color", "id": "button_background", "label": "Button background", "default": "#c99739" },
    { "type": "color", "id": "button_text_color", "label": "Button text color", "default": "#ffffff" },
    { "type": "header", "content": "Curved connector" },
    { "type": "range", "id": "connector_curve", "label": "Curve amount", "min": 0, "max": 24, "step": 2, "unit": "px", "default": 8 },
    { "type": "range", "id": "connector_width", "label": "Connector width", "min": 16, "max": 80, "step": 2, "unit": "px", "default": 32 },
    { "type": "range", "id": "connector_height", "label": "Connector height", "min": 80, "max": 220, "step": 4, "unit": "px", "default": 156 },
    { "type": "range", "id": "connector_thickness", "label": "Dash thickness", "min": 4, "max": 18, "step": 1, "unit": "px", "default": 11 },
    { "type": "range", "id": "connector_dash_length", "label": "Dash length", "min": 12, "max": 40, "step": 2, "unit": "px", "default": 18 },
    { "type": "range", "id": "connector_gap_length", "label": "Dash gap", "min": 10, "max": 42, "step": 2, "unit": "px", "default": 28 },
    { "type": "range", "id": "max_width", "label": "Content max width", "min": 640, "max": 1400, "step": 20, "unit": "px", "default": 760 },
    { "type": "range", "id": "mobile_padding_top", "label": "Mobile top padding", "min": 0, "max": 180, "step": 4, "unit": "px", "default": 120 },
    { "type": "range", "id": "mobile_padding_bottom", "label": "Mobile bottom padding", "min": 0, "max": 180, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "desktop_padding_top", "label": "Desktop top padding", "min": 0, "max": 220, "step": 4, "unit": "px", "default": 120 },
    { "type": "range", "id": "desktop_padding_bottom", "label": "Desktop bottom padding", "min": 0, "max": 220, "step": 4, "unit": "px", "default": 96 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Category name", "default": "TEA" },
        { "type": "text", "id": "button_label", "label": "Button text", "default": "SHOP NOW" },
        { "type": "url", "id": "link", "label": "Button and card link" },
        { "type": "checkbox", "id": "open_in_new_tab", "label": "Open link in new tab", "default": false },
        { "type": "range", "id": "card_rotation", "label": "Card rotation", "min": -8, "max": 8, "step": 1, "unit": "deg", "default": -2 },
        { "type": "color", "id": "card_background", "label": "Card background override", "default": "#fbefd9" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DV Gold shop by category",
      "blocks": [
        { "type": "category", "settings": { "title": "TEA", "card_rotation": 2 } },
        { "type": "category", "settings": { "title": "SPICE", "card_rotation": -4 } },
        { "type": "category", "settings": { "title": "DRY FRUITS", "card_rotation": 3 } },
        { "type": "category", "settings": { "title": "FARALI ITEMS", "card_rotation": -3 } }
      ]
    }
  ]
}
{% endschema %}
