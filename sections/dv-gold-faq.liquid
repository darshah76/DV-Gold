{% liquid
  assign section_anchor = 'dv-gold-faq-' | append: section.id
%}

<section
  id="{{ section_anchor }}"
  class="dv-faq dv-content-section color-{{ section.settings.color_scheme }}"
  style="
    --dv-faq-bg: {{ section.settings.background_color }};
    --dv-faq-heading: {{ section.settings.heading_color }};
    --dv-faq-card-bg: {{ section.settings.card_background }};
    --dv-faq-border: {{ section.settings.border_color }};
    --dv-faq-text: {{ section.settings.text_color }};
    --dv-faq-icon: {{ section.settings.icon_color }};
    --dv-faq-max-width: {{ section.settings.max_width }}px;
    --dv-faq-mobile-padding-top: {{ section.settings.mobile_padding_top }}px;
    --dv-faq-mobile-padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    --dv-faq-desktop-padding-top: {{ section.settings.desktop_padding_top }}px;
    --dv-faq-desktop-padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
  "
>
  <div class="dv-faq__inner dv-section-container">
    {% if section.settings.heading != blank %}
      <h2 class="dv-faq__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="dv-faq__items">
      {% for block in section.blocks %}
        <details class="dv-faq__item" {{ block.shopify_attributes }}>
          <summary class="dv-faq__summary">
            <span class="dv-faq__question">{{ block.settings.question }}</span>
            <span class="dv-faq__chevron" aria-hidden="true">
              <svg viewBox="0 0 20 20" focusable="false">
                <path d="M5 7.5 10 12.5 15 7.5" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </summary>

          {% if block.settings.answer != blank %}
            <div class="dv-faq__answer rte">
              {{ block.settings.answer }}
            </div>
          {% endif %}
        </details>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  {% render 'dv-gold-home-typography', section_anchor: section_anchor %}
  #{{ section_anchor }} {
    background: var(--dv-faq-bg);
    color: var(--dv-faq-text);
    padding-block: var(--dv-faq-mobile-padding-top) var(--dv-faq-mobile-padding-bottom);
  }

  #{{ section_anchor }} .dv-faq__inner {
    width: min(calc(100% - 32px), var(--dv-faq-max-width));
    margin-inline: auto;
  }

  #{{ section_anchor }} .dv-faq__heading {
    margin: 0 0 28px;
    color: var(--dv-faq-heading);
    font-family: var(--font-heading--family);
    font-size: var(--dv-section-heading-size);
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.04em;
    text-align: center;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .dv-faq__items {
    display: grid;
    gap: 14px;
  }

  #{{ section_anchor }} .dv-faq__item {
    overflow: hidden;
    border: 1px solid var(--dv-faq-border);
    border-radius: 18px;
    background: var(--dv-faq-card-bg);
    color: var(--dv-faq-text);
    box-shadow: 0 12px 28px rgba(74, 42, 20, 0.06);
  }

  #{{ section_anchor }} .dv-faq__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    min-height: 68px;
    padding: 20px 20px 18px;
    cursor: pointer;
    list-style: none;
  }

  #{{ section_anchor }} .dv-faq__summary::-webkit-details-marker {
    display: none;
  }

  #{{ section_anchor }} .dv-faq__question {
    color: var(--dv-faq-text);
    font-size: clamp(1.7rem, 4.4vw, 2rem);
    font-weight: 800;
    line-height: 1.22;
  }

  #{{ section_anchor }} .dv-faq__chevron {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    flex: 0 0 32px;
    color: var(--dv-faq-icon);
    transition: transform 180ms ease;
  }

  #{{ section_anchor }} .dv-faq__chevron svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  #{{ section_anchor }} .dv-faq__item[open] .dv-faq__chevron {
    transform: rotate(180deg);
  }

  #{{ section_anchor }} .dv-faq__answer {
    padding: 0 20px 22px;
    color: var(--dv-faq-text);
    font-size: clamp(1.5rem, 4vw, 1.75rem);
    line-height: 1.55;
  }

  #{{ section_anchor }} .dv-faq__answer > * {
    margin-block: 0 1em;
  }

  #{{ section_anchor }} .dv-faq__answer > *:last-child {
    margin-block-end: 0;
  }

  @media screen and (min-width: 750px) {
    #{{ section_anchor }} {
      padding-block: var(--dv-faq-desktop-padding-top) var(--dv-faq-desktop-padding-bottom);
    }

    #{{ section_anchor }} .dv-faq__inner {
      width: min(calc(100% - 64px), var(--dv-faq-max-width));
    }

    #{{ section_anchor }} .dv-faq__heading {
      margin-block-end: 40px;
      font-size: var(--dv-section-heading-size);
    }

    #{{ section_anchor }} .dv-faq__items {
      gap: 18px;
    }

    #{{ section_anchor }} .dv-faq__item {
      border-radius: 22px;
    }

    #{{ section_anchor }} .dv-faq__summary {
      min-height: 78px;
      padding: 24px 30px 22px;
    }

    #{{ section_anchor }} .dv-faq__question {
      font-size: clamp(1.9rem, 1.8vw, 2.3rem);
    }

    #{{ section_anchor }} .dv-faq__answer {
      padding: 0 30px 28px;
      font-size: clamp(1.6rem, 1.25vw, 1.9rem);
    }
  }
</style>

{% schema %}
{
  "name": "DV Gold FAQ",
  "tag": "section",
  "class": "section-dv-gold-faq",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "FAQ’S" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#fbf5ef" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#9b2d32" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#fffaf2" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#f0dfbf" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#191512" },
    { "type": "color", "id": "icon_color", "label": "Icon color", "default": "#c99700" },
    { "type": "range", "id": "max_width", "min": 360, "max": 1400, "step": 20, "unit": "px", "label": "Maximum width", "default": 760 },
    { "type": "range", "id": "mobile_padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Mobile padding top", "default": 76 },
    { "type": "range", "id": "mobile_padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Mobile padding bottom", "default": 88 },
    { "type": "range", "id": "desktop_padding_top", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Desktop padding top", "default": 88 },
    { "type": "range", "id": "desktop_padding_bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Desktop padding bottom", "default": 96 }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Add your answer here.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DV Gold FAQ",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "Global Shipping & Delivery", "answer": "<p>We carefully pack every order and provide delivery updates once your shipment is on its way.</p>" } },
        { "type": "faq_item", "settings": { "question": "Optimal Brewing Guides", "answer": "<p>Use fresh water, the recommended steeping time, and your preferred strength to enjoy DV Gold tea at its best.</p>" } },
        { "type": "faq_item", "settings": { "question": "Ethical Sourcing Standards", "answer": "<p>Our products are selected with a focus on trusted sourcing, premium quality, and consistent standards.</p>" } },
        { "type": "faq_item", "settings": { "question": "B2B & Wholesale Accounts", "answer": "<p>Contact our team for bulk orders, wholesale pricing, and partnership opportunities.</p>" } }
      ]
    }
  ]
}
{% endschema %}
