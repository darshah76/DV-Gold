{% liquid
  assign section_anchor = 'dv-gold-reviews-' | append: section.id
  assign modal_id = section_anchor | append: '-modal'
  assign modal_title_id = modal_id | append: '-title'
  assign confirmation_id = modal_id | append: '-confirmation'
%}

<section
  id="{{ section_anchor }}"
  class="dv-reviews color-{{ section.settings.color_scheme }}"
  style="
    --dv-reviews-bg: {{ section.settings.background_color }};
    --dv-reviews-heading: {{ section.settings.heading_color }};
    --dv-reviews-text: {{ section.settings.text_color }};
    --dv-reviews-card-bg: {{ section.settings.card_background }};
    --dv-reviews-border: {{ section.settings.border_color }};
    --dv-reviews-accent: {{ section.settings.accent_color }};
    --dv-reviews-button-bg: {{ section.settings.button_background }};
    --dv-reviews-button-text: {{ section.settings.button_text_color }};
    --dv-reviews-max-width: {{ section.settings.max_width }}px;
    --dv-reviews-padding-top-mobile: {{ section.settings.mobile_padding_top }}px;
    --dv-reviews-padding-bottom-mobile: {{ section.settings.mobile_padding_bottom }}px;
    --dv-reviews-padding-top-desktop: {{ section.settings.desktop_padding_top }}px;
    --dv-reviews-padding-bottom-desktop: {{ section.settings.desktop_padding_bottom }}px;
  "
>
  <div class="dv-reviews__inner">
    <div class="dv-reviews__header">
      {% if section.settings.eyebrow != blank %}
        <p class="dv-reviews__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="dv-reviews__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="dv-reviews__subheading">{{ section.settings.subheading | escape }}</p>
      {% endif %}

      <button
        type="button"
        class="dv-reviews__write-button"
        data-dv-review-open
        aria-haspopup="dialog"
        aria-controls="{{ modal_id }}"
      >
        {{ section.settings.button_label | escape }}
      </button>
    </div>

    <div class="dv-reviews__cards" role="list" aria-label="{{ section.settings.reviews_label | escape }}">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <article class="dv-reviews__card" role="listitem" {{ block.shopify_attributes }}>
            <div class="dv-reviews__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
              {% for i in (1..5) %}
                <span aria-hidden="true">{% if i <= block.settings.rating %}★{% else %}☆{% endif %}</span>
              {% endfor %}
            </div>
            {% if block.settings.review != blank %}
              <blockquote class="dv-reviews__quote">{{ block.settings.review }}</blockquote>
            {% endif %}
            {% if block.settings.author != blank %}
              <p class="dv-reviews__author">— {{ block.settings.author | escape }}</p>
            {% endif %}
          </article>
        {% endfor %}
      {% else %}
        <article class="dv-reviews__card" role="listitem">
          <div class="dv-reviews__stars" aria-label="5 out of 5 stars" aria-hidden="false">★★★★★</div>
          <blockquote class="dv-reviews__quote">Add customer reviews in the theme editor.</blockquote>
          <p class="dv-reviews__author">— DV Gold customer</p>
        </article>
      {% endif %}
    </div>
  </div>

  <div class="dv-review-modal" data-dv-review-modal hidden>
    <div class="dv-review-modal__backdrop" data-dv-review-close aria-hidden="true"></div>
    <div
      id="{{ modal_id }}"
      class="dv-review-modal__dialog"
      role="dialog"
      aria-modal="true"
      aria-labelledby="{{ modal_title_id }}"
      tabindex="-1"
    >
      <button type="button" class="dv-review-modal__close" data-dv-review-close aria-label="Close review form">
        <span aria-hidden="true">×</span>
      </button>

      <div class="dv-review-modal__content" data-dv-review-form-state>
        <p class="dv-review-modal__eyebrow">{{ section.settings.modal_eyebrow | escape }}</p>
        <h3 id="{{ modal_title_id }}" class="dv-review-modal__title">{{ section.settings.modal_title | escape }}</h3>

        <form class="dv-review-modal__form" action="" method="post" data-dv-review-form>
          <input type="hidden" name="form_type" value="dv_gold_review">
          <input type="hidden" name="section_id" value="{{ section.id }}">

          <div class="dv-review-modal__field">
            <label for="{{ modal_id }}-name">Name</label>
            <input id="{{ modal_id }}-name" name="review[name]" type="text" autocomplete="name" required>
          </div>

          <div class="dv-review-modal__field">
            <label for="{{ modal_id }}-rating">Rating</label>
            <select id="{{ modal_id }}-rating" name="review[rating]" required>
              <option value="5">5 stars</option>
              <option value="4">4 stars</option>
              <option value="3">3 stars</option>
              <option value="2">2 stars</option>
              <option value="1">1 star</option>
            </select>
          </div>

          <div class="dv-review-modal__field">
            <label for="{{ modal_id }}-review">Review</label>
            <textarea id="{{ modal_id }}-review" name="review[body]" rows="5" required></textarea>
          </div>

          <button type="submit" class="dv-review-modal__submit">Submit review</button>
        </form>
      </div>

      <div id="{{ confirmation_id }}" class="dv-review-modal__confirmation" data-dv-review-confirmation hidden tabindex="-1">
        <h3 class="dv-review-modal__title">Thank you for your review.</h3>
        <p>Your feedback has been received. This demo form is ready to connect to a reviews app, app proxy, or backend endpoint.</p>
        <button type="button" class="dv-review-modal__submit" data-dv-review-close>Close</button>
      </div>
    </div>
  </div>
</section>

<style>
  #{{ section_anchor }} {
    background: var(--dv-reviews-bg);
    color: var(--dv-reviews-text);
    padding-block: var(--dv-reviews-padding-top-mobile) var(--dv-reviews-padding-bottom-mobile);
  }

  #{{ section_anchor }} .dv-reviews__inner {
    width: min(calc(100% - 32px), var(--dv-reviews-max-width));
    margin-inline: auto;
  }

  #{{ section_anchor }} .dv-reviews__header {
    text-align: center;
    margin-inline: auto;
    max-width: 760px;
  }

  #{{ section_anchor }} .dv-reviews__eyebrow,
  #{{ section_anchor }} .dv-review-modal__eyebrow {
    color: var(--dv-reviews-accent);
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .dv-reviews__heading,
  #{{ section_anchor }} .dv-review-modal__title {
    color: var(--dv-reviews-heading);
    font-family: var(--font-heading--family);
    font-size: clamp(3.4rem, 9vw, 5.6rem);
    font-weight: 800;
    line-height: 1;
    margin: 0;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .dv-reviews__subheading {
    font-size: clamp(1.6rem, 4vw, 1.9rem);
    line-height: 1.55;
    margin: 18px auto 0;
    max-width: 620px;
  }

  #{{ section_anchor }} .dv-reviews__write-button,
  #{{ section_anchor }} .dv-review-modal__submit {
    appearance: none;
    border: 0;
    border-radius: 999px;
    background: var(--dv-reviews-button-bg);
    color: var(--dv-reviews-button-text);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font: inherit;
    font-weight: 800;
    margin-block-start: 28px;
    min-height: 48px;
    padding: 13px 28px;
    text-decoration: none;
    transition: opacity 160ms ease, transform 160ms ease;
  }

  #{{ section_anchor }} .dv-reviews__write-button:hover,
  #{{ section_anchor }} .dv-review-modal__submit:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  #{{ section_anchor }} .dv-reviews__cards {
    display: grid;
    gap: 18px;
    margin-block-start: 36px;
  }

  #{{ section_anchor }} .dv-reviews__card {
    background: var(--dv-reviews-card-bg);
    border: 1px solid var(--dv-reviews-border);
    border-radius: 22px;
    box-shadow: 0 14px 32px rgba(74, 42, 20, 0.07);
    padding: 24px;
  }

  #{{ section_anchor }} .dv-reviews__stars {
    color: var(--dv-reviews-accent);
    font-size: 2rem;
    letter-spacing: 0.08em;
    line-height: 1;
    margin-block-end: 16px;
  }

  #{{ section_anchor }} .dv-reviews__quote {
    font-size: clamp(1.55rem, 4vw, 1.8rem);
    line-height: 1.55;
    margin: 0;
  }

  #{{ section_anchor }} .dv-reviews__author {
    color: var(--dv-reviews-heading);
    font-weight: 800;
    margin: 18px 0 0;
  }

  #{{ section_anchor }} .dv-review-modal[hidden],
  #{{ section_anchor }} .dv-review-modal__confirmation[hidden] {
    display: none;
  }

  #{{ section_anchor }} .dv-review-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: grid;
    place-items: center;
    padding: 20px;
  }

  #{{ section_anchor }} .dv-review-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(25, 21, 18, 0.58);
  }

  #{{ section_anchor }} .dv-review-modal__dialog {
    position: relative;
    width: min(100%, 560px);
    max-height: min(86vh, 760px);
    overflow: auto;
    background: var(--dv-reviews-card-bg);
    border: 1px solid var(--dv-reviews-border);
    border-radius: 24px;
    box-shadow: 0 24px 80px rgba(25, 21, 18, 0.28);
    padding: 28px;
  }

  #{{ section_anchor }} .dv-review-modal__close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 40px;
    height: 40px;
    border: 1px solid var(--dv-reviews-border);
    border-radius: 999px;
    background: #fff;
    color: var(--dv-reviews-text);
    cursor: pointer;
    font-size: 2.8rem;
    line-height: 1;
  }

  #{{ section_anchor }} .dv-review-modal__content,
  #{{ section_anchor }} .dv-review-modal__confirmation {
    padding-block-start: 22px;
  }

  #{{ section_anchor }} .dv-review-modal__title {
    font-size: clamp(2.8rem, 7vw, 4rem);
    padding-inline-end: 34px;
  }

  #{{ section_anchor }} .dv-review-modal__form {
    display: grid;
    gap: 18px;
    margin-block-start: 24px;
  }

  #{{ section_anchor }} .dv-review-modal__field {
    display: grid;
    gap: 8px;
    text-align: left;
  }

  #{{ section_anchor }} .dv-review-modal__field label {
    font-size: 1.4rem;
    font-weight: 800;
  }

  #{{ section_anchor }} .dv-review-modal__field input,
  #{{ section_anchor }} .dv-review-modal__field select,
  #{{ section_anchor }} .dv-review-modal__field textarea {
    width: 100%;
    border: 1px solid var(--dv-reviews-border);
    border-radius: 14px;
    background: #fff;
    color: var(--dv-reviews-text);
    font: inherit;
    min-height: 48px;
    padding: 12px 14px;
  }

  #{{ section_anchor }} .dv-review-modal__field textarea {
    resize: vertical;
  }

  #{{ section_anchor }} .dv-review-modal__confirmation p {
    font-size: 1.6rem;
    line-height: 1.55;
    margin: 16px 0 0;
  }

  @media screen and (min-width: 750px) {
    #{{ section_anchor }} {
      padding-block: var(--dv-reviews-padding-top-desktop) var(--dv-reviews-padding-bottom-desktop);
    }

    #{{ section_anchor }} .dv-reviews__inner {
      width: min(calc(100% - 64px), var(--dv-reviews-max-width));
    }

    #{{ section_anchor }} .dv-reviews__cards {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-block-start: 48px;
    }

    #{{ section_anchor }} .dv-review-modal__dialog {
      padding: 36px;
    }
  }
</style>

<script>
  (() => {
    const section = document.getElementById({{ section_anchor | json }});

    if (!section || section.dataset.dvReviewModalReady === 'true') return;

    section.dataset.dvReviewModalReady = 'true';

    const modal = section.querySelector('[data-dv-review-modal]');
    const dialog = section.querySelector('[role="dialog"]');
    const openButton = section.querySelector('[data-dv-review-open]');
    const closeButtons = section.querySelectorAll('[data-dv-review-close]');
    const form = section.querySelector('[data-dv-review-form]');
    const formState = section.querySelector('[data-dv-review-form-state]');
    const confirmation = section.querySelector('[data-dv-review-confirmation]');
    let previousFocus = null;

    if (!modal || !dialog || !openButton) return;

    const focusableSelector = 'a[href], button:not([disabled]), textarea:not([disabled]), input:not([disabled]), select:not([disabled]), [tabindex]:not([tabindex="-1"])';

    const getFocusableElements = () => Array.from(dialog.querySelectorAll(focusableSelector)).filter((element) => element.offsetParent !== null);

    const closeModal = () => {
      modal.hidden = true;
      document.documentElement.classList.remove('dv-review-modal-open');

      if (formState) formState.hidden = false;
      if (confirmation) confirmation.hidden = true;
      if (form) form.reset();

      if (previousFocus && typeof previousFocus.focus === 'function') {
        previousFocus.focus();
      } else {
        openButton.focus();
      }
    };

    const openModal = () => {
      previousFocus = document.activeElement;
      modal.hidden = false;
      document.documentElement.classList.add('dv-review-modal-open');

      window.requestAnimationFrame(() => {
        const firstField = dialog.querySelector('input, select, textarea');
        (firstField || dialog).focus();
      });
    };

    openButton.addEventListener('click', openModal);
    closeButtons.forEach((button) => button.addEventListener('click', closeModal));

    document.addEventListener('keydown', (event) => {
      if (!modal.hidden && event.key === 'Escape') {
        event.preventDefault();
        closeModal();
      }
    });

    dialog.addEventListener('keydown', (event) => {
      if (event.key !== 'Tab') return;

      const focusableElements = getFocusableElements();
      const firstFocusable = focusableElements[0];
      const lastFocusable = focusableElements[focusableElements.length - 1];

      if (!firstFocusable || !lastFocusable) return;

      if (event.shiftKey && document.activeElement === firstFocusable) {
        event.preventDefault();
        lastFocusable.focus();
      } else if (!event.shiftKey && document.activeElement === lastFocusable) {
        event.preventDefault();
        firstFocusable.focus();
      }
    });

    form?.addEventListener('submit', (event) => {
      event.preventDefault();

      if (formState) formState.hidden = true;
      if (confirmation) {
        confirmation.hidden = false;
        confirmation.focus();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "DV Gold Reviews",
  "tag": "section",
  "class": "section-dv-gold-reviews",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Customer Reviews" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved by Tea Drinkers" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Read what customers are saying about DV Gold, then share your own experience." },
    { "type": "text", "id": "button_label", "label": "Write review button label", "default": "Write a Review" },
    { "type": "text", "id": "reviews_label", "label": "Reviews list accessibility label", "default": "Customer reviews" },
    { "type": "text", "id": "modal_eyebrow", "label": "Modal eyebrow", "default": "Share your experience" },
    { "type": "text", "id": "modal_title", "label": "Modal title", "default": "Write a Review" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#fbf5ef" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#9b2d32" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#191512" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#fffaf2" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#f0dfbf" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#c99700" },
    { "type": "color", "id": "button_background", "label": "Button background", "default": "#9b2d32" },
    { "type": "color", "id": "button_text_color", "label": "Button text", "default": "#ffffff" },
    { "type": "range", "id": "max_width", "min": 360, "max": 1400, "step": 20, "unit": "px", "label": "Maximum width", "default": 1120 },
    { "type": "range", "id": "mobile_padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Mobile padding top", "default": 76 },
    { "type": "range", "id": "mobile_padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Mobile padding bottom", "default": 88 },
    { "type": "range", "id": "desktop_padding_top", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Desktop padding top", "default": 88 },
    { "type": "range", "id": "desktop_padding_bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Desktop padding bottom", "default": 96 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "author", "label": "Author", "default": "Happy customer" },
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Rating", "default": 5 },
        { "type": "textarea", "id": "review", "label": "Review", "default": "Beautiful tea, excellent flavor, and a premium experience from the first cup." }
      ]
    }
  ],
  "presets": [
    {
      "name": "DV Gold Reviews",
      "blocks": [
        { "type": "review", "settings": { "author": "Amina R.", "rating": 5, "review": "Smooth, aromatic, and packaged beautifully. It has become part of my daily ritual." } },
        { "type": "review", "settings": { "author": "Daniel K.", "rating": 5, "review": "The quality is consistent and the flavor feels special enough for gifting." } },
        { "type": "review", "settings": { "author": "Priya S.", "rating": 5, "review": "DV Gold tastes refined and fresh. I love serving it when guests visit." } }
      ]
    }
  ]
}
{% endschema %}
