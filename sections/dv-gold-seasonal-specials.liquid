    background: var(--dv-seasonal-bg);
    color: var(--dv-seasonal-text);
    padding-block: 0;
  }

  #{{ section_anchor }} .dv-seasonal-specials__inner {
    margin-inline: auto;
    width: min(100% - 32px, var(--dv-seasonal-max-width));
  }

  #{{ section_anchor }} .dv-seasonal-specials__heading-wrap {
    margin: 0 auto clamp(34px, 8vw, 58px);
    text-align: center;
  }

  #{{ section_anchor }} .dv-seasonal-specials__heading {
    color: var(--dv-seasonal-heading);
    font-family: var(--font-heading--family);
    font-size: var(--dv-section-heading-size);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin: 0;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .dv-seasonal-specials__heading-accent {
    background: var(--dv-seasonal-accent);
    display: block;
    height: 5px;
    margin: 16px auto 0;
    width: 58px;
  }

  #{{ section_anchor }} .dv-seasonal-specials__layout,
  #{{ section_anchor }} .dv-seasonal-specials__combo-list {
    display: grid;
    gap: 28px;
  }

  #{{ section_anchor }} .dv-seasonal-specials__card {
    background: var(--dv-seasonal-card-bg);
    border-radius: 28px;
    box-shadow: 0 22px 34px rgba(65, 45, 25, 0.12);
    overflow: hidden;
  }

  #{{ section_anchor }} .dv-seasonal-specials__media {
    aspect-ratio: 1 / 1;
    background: rgba(154, 107, 53, 0.12);
    position: relative;
  }

  #{{ section_anchor }} .dv-seasonal-specials__image,
  #{{ section_anchor }} .dv-seasonal-specials__placeholder {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  #{{ section_anchor }} .dv-seasonal-specials__placeholder,
  #{{ section_anchor }} .dv-seasonal-specials__product-placeholder {
    align-items: center;
    display: flex;
    justify-content: center;
  }

  #{{ section_anchor }} .dv-seasonal-specials__placeholder-svg,
  #{{ section_anchor }} .dv-seasonal-specials__product-placeholder-svg {
    height: 60%;
    opacity: 0.35;
    width: 60%;
  }

  #{{ section_anchor }} .dv-seasonal-specials__badge {
    background: var(--dv-seasonal-badge-bg);
    border-radius: 999px;
    color: var(--dv-seasonal-badge-text);
    font-size: var(--dv-product-price-size);
    font-weight: 800;
    left: 20px;
    letter-spacing: 0.08em;
    line-height: 1;
    padding: 0.8rem 1.6rem;
    position: absolute;
    text-transform: uppercase;
    top: 20px;
  }

  #{{ section_anchor }} .dv-seasonal-specials__content {
    padding: clamp(28px, 7vw, 42px) clamp(28px, 7vw, 42px) clamp(30px, 7vw, 42px);
  }

  #{{ section_anchor }} .dv-seasonal-specials__title {
    color: var(--dv-seasonal-text);
    font-family: var(--font-heading--family);
    font-size: var(--dv-product-title-size);
    font-weight: 700;
    line-height: 1.08;
    margin: 0 0 0.8rem;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .dv-seasonal-specials__description,
  #{{ section_anchor }} .dv-seasonal-specials__product-description {
    color: var(--dv-seasonal-muted);
    font-size: var(--dv-product-description-size);
    line-height: 1.35;
    margin: 0;
  }

  #{{ section_anchor }} .dv-seasonal-specials__description > *,
  #{{ section_anchor }} .dv-seasonal-specials__product-description > * {
    margin-block: 0;
  }

  #{{ section_anchor }} .dv-seasonal-specials__purchase-row {
    align-items: center;
    display: flex;
    gap: 12px;
    justify-content: space-between;
    margin-top: 18px;
  }

  #{{ section_anchor }} .dv-seasonal-specials__prices {
    display: grid;
    flex: 1 1 auto;
    gap: 2px;
    min-width: 0;
  }

  #{{ section_anchor }} .dv-seasonal-specials__compare-price {
    color: var(--dv-seasonal-muted);
    font-size: var(--dv-product-price-size);
    opacity: 0.7;
    text-decoration: line-through;
  }

  #{{ section_anchor }} .dv-seasonal-specials__price {
    color: var(--dv-seasonal-heading);
    font-size: var(--dv-product-price-size);
    font-weight: 800 !important;
    letter-spacing: 0.04em;
    line-height: 1;
  }

  #{{ section_anchor }} .dv-seasonal-specials__form {
    flex: 0 0 auto;
    margin: 0;
  }

  #{{ section_anchor }} .dv-seasonal-specials__button {
    align-items: center;
    appearance: none;
    background: var(--dv-seasonal-button-bg);
    border: 0;
    border-radius: 50%;
    color: var(--dv-seasonal-button-text);
    cursor: pointer;
    display: inline-flex;
    flex: 0 0 auto;
    font: inherit;
    font-size: var(--dv-add-action-size, 1.5rem);
    font-weight: 700;
    height: 38px;
    justify-content: center;
    line-height: 1;
    padding: 0;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    width: 38px;
    min-height: 38px;
    min-width: 38px;
  }

  #{{ section_anchor }} .dv-seasonal-specials__button:hover,
  #{{ section_anchor }} .dv-seasonal-specials__button:focus-visible,
  #{{ section_anchor }} .dv-seasonal-specials__product-button:hover,
  #{{ section_anchor }} .dv-seasonal-specials__product-button:focus-visible {
    box-shadow: 0 8px 14px rgba(70, 43, 18, 0.18);
    transform: translateY(-1px);
  }

  #{{ section_anchor }} .dv-seasonal-specials__button:disabled,
  #{{ section_anchor }} .dv-seasonal-specials__product-button:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  #{{ section_anchor }} .dv-seasonal-specials__products-wrap {
    display: grid;
    gap: 22px;
    min-width: 0;
  }

  #{{ section_anchor }} .dv-seasonal-specials__product-grid {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  #{{ section_anchor }} .dv-seasonal-specials__product-grid::-webkit-scrollbar {
    display: none;
  }

  #{{ section_anchor }} .dv-seasonal-specials__products-wrap--right_scroll .dv-seasonal-specials__product-grid {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none !important;
    -ms-overflow-style: none !important;
  }

  #{{ section_anchor }} .dv-seasonal-specials__products-wrap--right_scroll .dv-seasonal-specials__product-grid::-webkit-scrollbar {
    display: none !important;
    width: 0 !important;
    height: 0 !important;
  }

  #{{ section_anchor }} .dv-seasonal-specials__products-wrap--right_scroll .dv-seasonal-specials__product-card {
    flex-basis: min(78vw, 280px);
    min-width: min(78vw, 280px);
  }

  #{{ section_anchor }} .dv-seasonal-specials__product-card {
    background: var(--dv-seasonal-product-card-bg);
    border: 1px solid rgba(154, 107, 53, 0.18);
    border-radius: var(--brand-home-card-radius, 24px);
    overflow: hidden;
    display: flex;
    flex: 0 0 100%;
    flex-direction: column;
    min-width: 100%;
    padding: clamp(18px, 4.5vw, 24px);
    scroll-snap-align: start;
    box-shadow: none !important;
  }

  #{{ section_anchor }} .dv-seasonal-specials__product-media {
    background: #fbf0e1;
    border-radius: clamp(12px, 2vw, 18px);
    display: block;
    overflow: hidden;
    text-decoration: none;
  }

  #{{ section_anchor }} .dv-seasonal-specials__product-image,
  #{{ section_anchor }} .dv-seasonal-specials__product-placeholder {
    aspect-ratio: 1 / 1;
    display: block;
    height: auto;
    object-fit: contain;
    width: 100%;
  }

  #{{ section_anchor }} .dv-seasonal-specials__product-content {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    padding-top: 20px;
  }

  #{{ section_anchor }} .dv-seasonal-specials__product-title {
    color: var(--dv-seasonal-heading);
    font-family: var(--font-heading--family);
    font-size: var(--dv-product-title-size);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 0.6rem;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .dv-seasonal-specials__product-description {
    font-size: var(--dv-product-description-size);
  }

  #{{ section_anchor }} .dv-seasonal-specials__product-footer {
    align-items: center;
    display: flex;
    gap: 12px;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 18px;
  }

  #{{ section_anchor }} .dv-seasonal-specials__product-price {
    color: var(--dv-seasonal-heading);
    font-size: var(--dv-product-price-size);
    font-weight: 800 !important;
    line-height: 1;
  }

  #{{ section_anchor }} .dv-seasonal-specials__product-form {
    margin: 0;
  }

  #{{ section_anchor }} .dv-seasonal-specials__button,
  #{{ section_anchor }} .dv-seasonal-specials__product-button,
  #{{ section_anchor }} .dv-seasonal-specials__form button,
  #{{ section_anchor }} .dv-seasonal-specials__product-form button {
    align-items: center !important;
    appearance: none !important;
    background: var(--dv-seasonal-button-bg) !important;
    border: 0 !important;
    border-radius: 50% !important;
    color: var(--dv-seasonal-button-text) !important;
    cursor: pointer !important;
    display: inline-flex !important;
    flex: 0 0 38px !important;
    font: inherit !important;
    font-size: clamp(1.3rem, 2vw, 1.7rem) !important;
    font-weight: 700 !important;
    height: 38px !important;
    width: 38px !important;
    min-height: 38px !important;
    max-height: 38px !important;
    min-width: 38px !important;
    max-width: 38px !important;
    aspect-ratio: 1 / 1 !important;
    justify-content: center !important;
    line-height: 1 !important;
    padding: 0 !important;
    text-decoration: none !important;
    transition: transform 0.2s ease, box-shadow 0.2s ease !important;
    box-shadow: 0 4px 10px rgba(65, 45, 25, 0.18) !important;
    box-sizing: border-box !important;
  }

  #{{ section_anchor }} .dv-seasonal-specials__product-dots {
    align-items: center;
    display: flex;
    gap: 5px;
    justify-content: center;
  }

  #{{ section_anchor }} .dv-seasonal-specials__product-dot {
    background: var(--dv-seasonal-heading);
    border-radius: 50%;
    appearance: none;
    border: 0;
    cursor: pointer;
    display: block;
    height: 10px;
    opacity: 0.45;
    padding: 0;
    width: 10px;
  }

  #{{ section_anchor }} .dv-seasonal-specials__product-dot.is-active {
    opacity: 1;
    transform: scale(1.08);
  }

  #{{ section_anchor }} .dv-seasonal-specials__empty {
    color: var(--dv-seasonal-muted);
    margin: 0;
    text-align: center;
  }



  @media screen and (min-width: 750px) {
    #{{ section_anchor }} {
      padding-block: 0;
    }

    #{{ section_anchor }} .dv-seasonal-specials__inner {
      width: min(100% - 64px, var(--dv-seasonal-max-width));
    }

    #{{ section_anchor }} .dv-seasonal-specials__layout {
      align-items: start;
      grid-template-columns: minmax(0, 20vw) minmax(0, 1fr);
    }

    #{{ section_anchor }} .dv-seasonal-specials__combo-list {
      max-width: 20vw;
      width: 100%;
    }

    #{{ section_anchor }} .dv-seasonal-specials__products-wrap--right_scroll .dv-seasonal-specials__product-card {
      flex-basis: min(30vw, 280px);
      min-width: min(30vw, 280px);
    }
  }
</style>

<script>
  (() => {
    const initSeasonalProducts = (root = document) => {
      root.querySelectorAll('[data-dv-seasonal-products]').forEach((carousel) => {
        if (carousel.dataset.dvSeasonalProductsInitialized === 'true') return;
        if (carousel.dataset.displayMode !== 'carousel') return;

        const track = carousel.querySelector('[data-dv-seasonal-products-track]');
        const slides = Array.from(carousel.querySelectorAll('[data-dv-seasonal-products-slide]'));
        const dots = Array.from(carousel.querySelectorAll('[data-dv-seasonal-products-dot]'));

        if (!track || slides.length < 2 || dots.length === 0) return;

        carousel.dataset.dvSeasonalProductsInitialized = 'true';

        let activeSlideIndex = 0;
        let autoplayTimer;

        const setActiveDot = (activeIndex) => {
          activeSlideIndex = activeIndex;
          dots.forEach((dot, index) => {
            const isActive = index === activeIndex;
            dot.classList.toggle('is-active', isActive);
            dot.setAttribute('aria-selected', isActive ? 'true' : 'false');
          });
        };

        const scrollToSlide = (index, behavior = 'smooth') => {
          const slide = slides[index];
          if (!slide) return;

          track.scrollTo({ left: slide.offsetLeft - track.offsetLeft, behavior });
          setActiveDot(index);
        };

        const stopAutoplay = () => {
          if (autoplayTimer) window.clearInterval(autoplayTimer);
        };

        const startAutoplay = () => {
          stopAutoplay();

          if (carousel.dataset.autoplay !== 'true') return;

          const autoplaySpeed = Number(carousel.dataset.autoplaySpeed || 0);
          if (!autoplaySpeed || autoplaySpeed < 1000) return;

          autoplayTimer = window.setInterval(() => {
            const nextIndex = (activeSlideIndex + 1) % slides.length;
            scrollToSlide(nextIndex);
          }, autoplaySpeed);
        };

        dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            const index = Number(dot.dataset.slideIndex || 0);
            scrollToSlide(index);
            startAutoplay();
          });
        });

        track.addEventListener('scroll', () => {
          const activeIndex = slides.reduce((closestIndex, slide, index) => {
            const currentDistance = Math.abs(slide.offsetLeft - track.offsetLeft - track.scrollLeft);
            const closestSlide = slides[closestIndex];
            const closestDistance = Math.abs(closestSlide.offsetLeft - track.offsetLeft - track.scrollLeft);
            return currentDistance < closestDistance ? index : closestIndex;
          }, 0);

          setActiveDot(activeIndex);
        }, { passive: true });

        carousel.addEventListener('mouseenter', stopAutoplay);
        carousel.addEventListener('mouseleave', startAutoplay);
        carousel.addEventListener('focusin', stopAutoplay);
        carousel.addEventListener('focusout', startAutoplay);
        startAutoplay();
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => initSeasonalProducts());
    } else {
      initSeasonalProducts();
    }

    document.addEventListener('shopify:section:load', (event) => initSeasonalProducts(event.target));
  })();
</script>

