<script src="{{ 'facets.js' | asset_url }}" type="module" fetchpriority="low"></script>

{% liquid
  assign hero_eyebrow = section.settings.hero_eyebrow | default: 'DV GOLD COLLECTION'
  assign hero_heading = section.settings.hero_heading | default: collection.title
  assign hero_text = section.settings.hero_text | default: collection.description | strip_html
  assign hero_button_label = section.settings.hero_button_label | default: 'Shop Bestsellers'
  assign hero_button_link = section.settings.hero_button_link | default: '#dv-gold-collection-products'
  assign products_per_page = section.settings.products_per_page
  assign sort_by = collection.sort_by | default: collection.default_sort_by
%}

<section
  class="dv-collection"
  style="
    --dv-page-bg: {{ section.settings.page_background }};
    --dv-card-bg: {{ section.settings.hero_card_background }};
    --dv-heading: {{ section.settings.heading_color }};
    --dv-text: {{ section.settings.text_color }};
    --dv-accent: {{ section.settings.accent_color }};
    --dv-product-bg: {{ section.settings.product_card_background }};
    --dv-image-bg: {{ section.settings.product_image_background }};
  "
>
  <div class="dv-collection__hero-wrap">
    <div class="dv-collection__hero">
      {% if hero_eyebrow != blank %}
        <p class="dv-collection__eyebrow">{{ hero_eyebrow }}</p>
      {% endif %}
      {% if hero_heading != blank %}
        <h1 class="dv-collection__title">{{ hero_heading }}</h1>
      {% endif %}
      {% if hero_text != blank %}
        <div class="dv-collection__intro">{{ hero_text }}</div>
      {% endif %}
      {% if hero_button_label != blank %}
        <a class="dv-collection__button" href="{{ hero_button_link }}">{{ hero_button_label }}</a>
      {% endif %}
    </div>
  </div>

  <div class="dv-collection__toolbar" aria-label="Collection controls">
    <facets-form-component
      class="dv-collection__facets"
      section-id="{{ section.id }}"
      data-collection-id="{{ collection.id }}"
      data-collection-handle="{{ collection.handle }}"
    >
      <form ref="facetsForm" class="dv-collection__facets-form" method="get">
        {% if collection.filters.size > 0 %}
          <details class="dv-collection__filter-menu">
            <summary class="dv-collection__tool" aria-label="Open filters">
              <span class="dv-collection__filter-icon" aria-hidden="true"></span>
              <span>Filter</span>
            </summary>
            <div class="dv-collection__filter-panel">
              {% for filter in collection.filters %}
                <fieldset class="dv-collection__filter-group">
                  <legend>{{ filter.label }}</legend>
                  {% for value in filter.values %}
                    <label class="dv-collection__filter-option">
                      <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}" {% if value.active %}checked{% endif %} {% if value.count == 0 and value.active == false %}disabled{% endif %}>
                      <span>{{ value.label }} ({{ value.count }})</span>
                    </label>
                  {% endfor %}
                </fieldset>
              {% endfor %}
              <button class="dv-collection__apply" type="submit">Apply</button>
            </div>
          </details>
        {% else %}
          <span class="dv-collection__tool dv-collection__tool--disabled">
            <span class="dv-collection__filter-icon" aria-hidden="true"></span>
            <span>Filter</span>
          </span>
        {% endif %}

        <div class="dv-collection__sort">
          <label class="visually-hidden" for="SortBy-{{ section.id }}">Sort by</label>
          <select id="SortBy-{{ section.id }}" name="sort_by" onchange="this.form.requestSubmit()">
            {% for option in collection.sort_options %}
              <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>Sort by {{ option.name }}</option>
            {% endfor %}
          </select>
          <span aria-hidden="true">⌄</span>
        </div>
      </form>
    </facets-form-component>
  </div>

  <div id="dv-gold-collection-products" class="dv-collection__content">
    {% if section.settings.products_heading != blank %}
      <h2 class="dv-collection__section-title">{{ section.settings.products_heading }}</h2>
    {% endif %}

    {% paginate collection.products by products_per_page %}
      <div class="dv-collection__grid" role="list">
        {% for product in collection.products %}
          {% liquid
            assign product_image = product.featured_image
            assign selected_variant = product.selected_or_first_available_variant
            assign badge_text = product.metafields.custom.badge.value | default: product.tags.first
          %}
          <article class="dv-collection__product" role="listitem">
            <a class="dv-collection__image-link" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
              {% if badge_text != blank %}
                <span class="dv-collection__badge">{{ badge_text }}</span>
              {% endif %}
              {% if product_image != blank %}
                {{
                  product_image
                  | image_url: width: 640
                  | image_tag:
                    loading: 'lazy',
                    widths: '220, 320, 440, 640',
                    sizes: '(min-width: 990px) 260px, 43vw',
                    class: 'dv-collection__image',
                    alt: product_image.alt
                }}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'dv-collection__placeholder' }}
              {% endif %}
            </a>
            <div class="dv-collection__product-body">
              <h3 class="dv-collection__product-title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
              {% if section.settings.show_description %}
                <p class="dv-collection__description">{{ product.description | strip_html | truncate: section.settings.description_length }}</p>
              {% endif %}
              <div class="dv-collection__footer">
                <p class="dv-collection__price">{{ product.price | money }}</p>
                {% if section.settings.show_quick_add %}
                  {% form 'product', product, class: 'dv-collection__form' %}
                    <input type="hidden" name="id" value="{{ selected_variant.id }}">
                    <button class="dv-collection__add" type="submit" {% unless selected_variant.available %}disabled{% endunless %} aria-label="Add {{ product.title | escape }} to cart">+</button>
                  {% endform %}
                {% endif %}
              </div>
            </div>
          </article>
        {% else %}
          <p class="dv-collection__empty">No products found in this collection.</p>
        {% endfor %}
      </div>
      {% if paginate.pages > 1 %}
        <div class="dv-collection__pagination">{{ paginate | default_pagination }}</div>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

<style>
  .dv-collection { background: var(--dv-page-bg); color: var(--dv-text); min-height: 100vh; }
  .dv-collection__hero-wrap { padding: 24px 24px 44px; border-bottom: 1px solid rgba(199, 159, 87, .22); }
  .dv-collection__hero { position: relative; width: min(100%, 920px); margin: 0 auto; padding: 26px 22px 0; text-align: center; background: var(--dv-card-bg); border: 1px solid rgba(213, 169, 90, .2); border-radius: 20px; box-shadow: 0 18px 24px rgba(91, 63, 27, .12); }
  .dv-collection__eyebrow { margin: 0 0 14px; color: var(--dv-accent); font-size: 1.1rem; font-weight: 800; letter-spacing: .18em; line-height: 1; text-transform: uppercase; }
  .dv-collection__title { max-width: 640px; margin: 0 auto 14px; color: var(--dv-heading); font-family: var(--font-heading--family); font-size: clamp(3.1rem, 8vw, 6.4rem); font-weight: 800; line-height: .95; }
  .dv-collection__intro { max-width: 560px; margin: 0 auto; color: var(--dv-text); font-size: 1.4rem; line-height: 1.45; }
  .dv-collection__button { display: inline-flex; min-width: 142px; min-height: 36px; align-items: center; justify-content: center; margin: 28px auto -18px; padding: 10px 24px; border-radius: 999px; background: var(--dv-accent); color: #fff; font-size: 1.2rem; font-weight: 800; text-decoration: none; box-shadow: 0 8px 14px rgba(203, 148, 0, .2); }
  .dv-collection__toolbar { display: flex; min-height: 68px; align-items: center; justify-content: space-between; border-block: 1px solid rgba(199, 159, 87, .22); }
  .dv-collection__facets, .dv-collection__facets-form { display: flex; width: 100%; min-height: 68px; }
  .dv-collection__filter-menu { position: relative; flex: 1; margin: 0; }
  .dv-collection__tool, .dv-collection__sort { flex: 1; display: flex; align-items: center; justify-content: center; gap: 12px; height: 68px; border: 0; background: transparent; color: #6b6255; font: inherit; font-size: 1.8rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
  .dv-collection__tool { width: 100%; border-right: 1px solid rgba(199, 159, 87, .22); cursor: pointer; list-style: none; }
  .dv-collection__tool::-webkit-details-marker { display: none; }
  .dv-collection__tool--disabled { cursor: default; opacity: .55; }
  .dv-collection__filter-panel { position: absolute; z-index: 4; inset-block-start: calc(100% + 10px); inset-inline-start: 12px; width: min(88vw, 340px); max-height: 70vh; overflow: auto; border: 1px solid rgba(199, 159, 87, .24); border-radius: 18px; background: #fffdf9; padding: 18px; box-shadow: 0 16px 40px rgba(91, 63, 27, .16); }
  .dv-collection__filter-group { margin: 0 0 16px; padding: 0; border: 0; }
  .dv-collection__filter-group legend { margin-block-end: 8px; color: var(--dv-heading); font-weight: 800; }
  .dv-collection__filter-option { display: flex; gap: 8px; align-items: center; padding-block: 5px; color: var(--dv-text); font-size: 1.3rem; font-weight: 700; letter-spacing: 0; text-transform: none; }
  .dv-collection__apply { width: 100%; min-height: 42px; border: 0; border-radius: 999px; background: var(--dv-accent); color: #fff; cursor: pointer; font: inherit; font-weight: 800; }
  .dv-collection__filter-icon { width: 17px; height: 17px; background: linear-gradient(var(--dv-accent),var(--dv-accent)) 0 4px/17px 1.5px no-repeat, linear-gradient(var(--dv-accent),var(--dv-accent)) 0 12px/17px 1.5px no-repeat; position: relative; }
  .dv-collection__filter-icon:before, .dv-collection__filter-icon:after { content: ''; position: absolute; width: 4px; height: 4px; border: 1px solid var(--dv-accent); border-radius: 50%; background: var(--dv-page-bg); top: 2px; left: 4px; }
  .dv-collection__filter-icon:after { top: 10px; left: 10px; }
  .dv-collection__sort select { appearance: none; border: 0; background: transparent; color: inherit; font: inherit; font-size: inherit; font-weight: inherit; letter-spacing: inherit; text-transform: inherit; max-width: 145px; cursor: pointer; }
  .dv-collection__sort span { color: var(--dv-accent); font-size: 1.8rem; transform: translateY(-2px); }
  .dv-collection__content { width: min(100% - 34px, 1180px); margin: 0 auto; padding: 32px 0 48px; }
  .dv-collection__section-title { margin: 0 0 56px; color: var(--dv-heading); font-family: var(--font-heading--family); font-size: clamp(2rem, 5.2vw, 4.2rem); font-weight: 800; line-height: 1; text-transform: uppercase; }
  .dv-collection__grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px 30px; }
  .dv-collection__product { display: flex; flex-direction: column; min-width: 0; overflow: hidden; border-radius: 7px; background: var(--dv-product-bg); box-shadow: 0 5px 12px rgba(98, 68, 32, .12); }
  .dv-collection__image-link { position: relative; display: flex; align-items: center; justify-content: center; margin: 11px 8px 0; aspect-ratio: 1 / 1.06; border-radius: 7px; background: var(--dv-image-bg); overflow: hidden; text-decoration: none; }
  .dv-collection__badge { position: absolute; top: 8px; left: 8px; z-index: 1; padding: 3px 8px; border-radius: 999px; background: #fffaf0; color: var(--dv-accent); font-size: .8rem; font-weight: 700; line-height: 1; }
  .dv-collection__image, .dv-collection__placeholder { width: 86%; height: 86%; object-fit: contain; display: block; }
  .dv-collection__product-body { display: flex; flex: 1; flex-direction: column; padding: 16px 12px 14px; }
  .dv-collection__product-title { margin: 0 0 9px; color: var(--dv-heading); font-family: var(--font-heading--family); font-size: 1.3rem; font-weight: 800; line-height: 1.15; text-transform: uppercase; }
  .dv-collection__product-title a { color: inherit; text-decoration: none; }
  .dv-collection__description { margin: 0 0 22px; color: var(--dv-text); font-size: 1.1rem; line-height: 1.38; }
  .dv-collection__footer { display: flex; align-items: flex-end; justify-content: space-between; gap: 10px; margin-top: auto; }
  .dv-collection__price { margin: 0; color: var(--dv-heading); font-size: 1.65rem; font-weight: 900; line-height: 1; }
  .dv-collection__form { margin: 0; }
  .dv-collection__add { width: 32px; height: 32px; border: 0; border-radius: 10px; background: var(--dv-accent); color: #fff; cursor: pointer; font-size: 1.8rem; font-weight: 800; line-height: 1; }
  .dv-collection__pagination { margin-top: 36px; text-align: center; }
  .dv-collection__empty { grid-column: 1 / -1; text-align: center; }
  @media (min-width: 750px) { .dv-collection__hero-wrap { padding: 48px 40px 64px; } .dv-collection__hero { padding: 48px 44px 0; border-radius: 28px; } .dv-collection__toolbar { width: min(100%, 1180px); margin: 0 auto; border-inline: 1px solid rgba(199,159,87,.22); } .dv-collection__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 28px; } .dv-collection__product-title { font-size: 1.6rem; } .dv-collection__description { font-size: 1.35rem; } .dv-collection__price { font-size: 2rem; } .dv-collection__add { width: 40px; height: 40px; border-radius: 13px; } }
  @media (min-width: 1100px) { .dv-collection__grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } .dv-collection__content { padding-top: 48px; } }
</style>

{% schema %}
{
  "name": "DV Gold collection",
  "enabled_on": { "templates": ["collection"] },
  "settings": [
    { "type": "text", "id": "hero_eyebrow", "label": "Hero eyebrow", "default": "DV GOLD COLLECTION" },
    { "type": "text", "id": "hero_heading", "label": "Hero heading", "default": "Premium Tea Collection" },
    { "type": "richtext", "id": "hero_text", "label": "Hero text", "default": "<p>Discover aromatic blends crafted for everyday freshness, purity, and consistent taste.</p>" },
    { "type": "text", "id": "hero_button_label", "label": "Hero button label", "default": "Shop Bestsellers" },
    { "type": "url", "id": "hero_button_link", "label": "Hero button link" },
    { "type": "text", "id": "products_heading", "label": "Products heading", "default": "Curated Selection" },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 4, "max": 48, "step": 4, "default": 12 },
    { "type": "checkbox", "id": "show_description", "label": "Show product description", "default": true },
    { "type": "range", "id": "description_length", "label": "Description length", "min": 40, "max": 160, "step": 10, "default": 70 },
    { "type": "checkbox", "id": "show_quick_add", "label": "Show quick add", "default": true },
    { "type": "color", "id": "page_background", "label": "Page background", "default": "#f8efe2" },
    { "type": "color", "id": "hero_card_background", "label": "Hero card background", "default": "#fffdf9" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#a91e35" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#4f453a" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#cf9200" },
    { "type": "color", "id": "product_card_background", "label": "Product card background", "default": "#ffffff" },
    { "type": "color", "id": "product_image_background", "label": "Product image background", "default": "#f7ecdd" }
  ],
  "presets": [{ "name": "DV Gold collection" }]
}
{% endschema %}
