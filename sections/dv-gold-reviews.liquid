        { "type": "text", "id": "badge", "label": "Badge text", "default": "VERIFIED BUYER" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DV Gold Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "author": "Ananya Shah",
            "body": "DV Gold has become my first choice for festive gifting. The sweets arrived fresh, beautifully packed, and every bite tasted rich and authentic.",
