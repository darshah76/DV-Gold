          "settings": {
            "author": "Priya Iyer",
            "body": "Loved the elegant packaging and the flavour of every mithai. It made our family celebration feel even more special.",
            "badge": "VERIFIED BUYER"
          }
        }
      ]
    }
  ]
}
{% endschema %}
