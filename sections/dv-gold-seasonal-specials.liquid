{% liquid
  assign section_anchor = 'dv-gold-seasonal-specials-' | append: section.id
  assign combo_count = 0
  assign product_card_count = 0
  for block in section.blocks
    if block.type == 'combo'
      assign combo_count = combo_count | plus: 1
    elsif block.type == 'side_product'
      assign product_card_count = product_card_count | plus: 1
    endif
  endfor
%}

<section
  id="{{ section_anchor }}"
  class="dv-seasonal-specials dv-content-section color-{{ section.settings.color_scheme }}"
  style="
    --dv-seasonal-bg: {{ section.settings.background_color }};
    --dv-seasonal-card-bg: {{ section.settings.card_background }};
    --dv-seasonal-product-card-bg: {{ section.settings.product_card_background }};
    --dv-seasonal-heading: {{ section.settings.heading_color }};
    --dv-seasonal-text: {{ section.settings.text_color }};
    --dv-seasonal-muted: {{ section.settings.muted_text_color }};
    --dv-seasonal-accent: {{ section.settings.accent_color }};
    --dv-seasonal-badge-bg: {{ section.settings.badge_background }};
    --dv-seasonal-badge-text: {{ section.settings.badge_text_color }};
    --dv-seasonal-button-bg: {{ section.settings.button_background }};
    --dv-seasonal-button-text: {{ section.settings.button_text_color }};
    --dv-seasonal-max-width: {{ section.settings.max_width }}px;
    --dv-seasonal-mobile-padding-top: {{ section.settings.mobile_padding_top }}px;
    --dv-seasonal-mobile-padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    --dv-seasonal-desktop-padding-top: {{ section.settings.desktop_padding_top }}px;
    --dv-seasonal-desktop-padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
  "
>
  <div class="dv-seasonal-specials__inner dv-section-container">
    {% if section.settings.heading != blank %}
      <div class="dv-seasonal-specials__heading-wrap">
        <h2 class="dv-seasonal-specials__heading">{{ section.settings.heading }}</h2>
        {% if section.settings.show_heading_accent %}
          <span class="dv-seasonal-specials__heading-accent" aria-hidden="true"></span>
        {% endif %}
      </div>
    {% endif %}

    {% if combo_count > 0 or product_card_count > 0 %}
      <div class="dv-seasonal-specials__layout">
        {% if combo_count > 0 %}
          <div class="dv-seasonal-specials__combo-list" role="list" aria-label="Combo specials">
            {% for block in section.blocks %}
              {% if block.type == 'combo' %}
                {% liquid
                  assign selected_product = block.settings.product
                  assign product_variant = selected_product.selected_or_first_available_variant
                  assign card_link = block.settings.link
                  if card_link == blank and selected_product != blank
                    assign card_link = selected_product.url
                  endif
                  assign button_label = block.settings.button_label
                  assign button_action = block.settings.button_action
                  assign card_title = selected_product.title
                %}

                <article class="dv-seasonal-specials__card" role="listitem" {{ block.shopify_attributes }}>
                  <div class="dv-seasonal-specials__media">
                    {% if selected_product.featured_image != blank %}
                      {{
                        selected_product.featured_image
                        | image_url: width: 1400
                        | image_tag:
                          loading: 'lazy',
                          widths: '360, 540, 720, 900, 1100, 1400',
                          sizes: '(min-width: 990px) 640px, calc(100vw - 60px)',
                          class: 'dv-seasonal-specials__image',
                          alt: selected_product.featured_image.alt
                      }}
                    {% else %}
                      <div class="dv-seasonal-specials__placeholder" aria-hidden="true">
                        {{ 'product-1' | placeholder_svg_tag: 'dv-seasonal-specials__placeholder-svg' }}
                      </div>
                    {% endif %}

                    {% if block.settings.badge_text != blank %}
                      <span class="dv-seasonal-specials__badge">{{ block.settings.badge_text }}</span>
                    {% endif %}
                  </div>

                  <div class="dv-seasonal-specials__content">
                    {% if card_title != blank %}
                      <h3 class="dv-seasonal-specials__title">{{ card_title }}</h3>
                    {% endif %}

                    <div class="dv-seasonal-specials__purchase-row">
                      <div class="dv-seasonal-specials__prices" aria-label="Price">
                        {% if selected_product.compare_at_price_max > selected_product.price %}
                          <span class="dv-seasonal-specials__compare-price">{{ selected_product.compare_at_price_max | money }}</span>
                        {% endif %}

                        {% if selected_product != blank %}
                          <span class="dv-seasonal-specials__price">{{ selected_product.price | money }}</span>
                        {% endif %}
                      </div>

                      {% if button_label != blank %}
                        {% if button_action == 'add_to_cart' and product_variant != blank %}
                          <form method="post" action="{{ routes.cart_add_url }}" class="dv-seasonal-specials__form">
                            <input type="hidden" name="id" value="{{ product_variant.id }}">
                            <input type="hidden" name="quantity" value="1">
                            <button
                              type="submit"
                              class="dv-seasonal-specials__button"
                              aria-label="{{ button_label | escape }} {{ card_title | escape }}"
                              {% unless product_variant.available %}disabled{% endunless %}
                            >
                              +
                            </button>
                          </form>
                        {% else %}
                          <a
                            class="dv-seasonal-specials__button"
                            href="{{ card_link | default: routes.all_products_collection_url }}"
                            aria-label="{{ button_label | escape }} {{ card_title | escape }}"
                          >
                            +
                          </a>
                        {% endif %}
                      {% endif %}
                    </div>
                  </div>
                </article>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}

        {% if product_card_count > 0 %}
          <div
            class="dv-seasonal-specials__products-wrap dv-seasonal-specials__products-wrap--{{ section.settings.product_display_mode }}"
            data-dv-seasonal-products
            data-display-mode="{{ section.settings.product_display_mode }}"
            data-autoplay="{{ section.settings.product_autoplay }}"
            data-autoplay-speed="{{ section.settings.product_autoplay_speed | times: 1000 }}"
          >
            {% assign product_slide_index = 0 %}
            <div class="dv-seasonal-specials__product-grid" role="list" aria-label="Featured products" data-dv-seasonal-products-track>
              {% for block in section.blocks %}
              {% if block.type == 'side_product' %}
                {% liquid
                  assign card_product = block.settings.product
                  assign card_variant = card_product.selected_or_first_available_variant
                  assign product_link = block.settings.link
                  if product_link == blank and card_product != blank
                    assign product_link = card_product.url
                  endif
                  assign product_title = card_product.title
                %}

                {% assign product_slide_index = product_slide_index | plus: 1 %}
                <article class="dv-seasonal-specials__product-card" role="listitem" data-dv-seasonal-products-slide data-slide-index="{{ product_slide_index | minus: 1 }}" {{ block.shopify_attributes }}>
                  <a class="dv-seasonal-specials__product-media" href="{{ product_link | default: routes.all_products_collection_url }}">
                    {% if card_product.featured_image != blank %}
                      {{
                        card_product.featured_image
                        | image_url: width: 600
                        | image_tag:
                          loading: 'lazy',
                          widths: '180, 260, 360, 480, 600',
                          sizes: '(min-width: 990px) 240px, 44vw',
                          class: 'dv-seasonal-specials__product-image',
                          alt: card_product.featured_image.alt
                      }}
                    {% else %}
                      <div class="dv-seasonal-specials__product-placeholder" aria-hidden="true">
                        {{ 'product-2' | placeholder_svg_tag: 'dv-seasonal-specials__product-placeholder-svg' }}
                      </div>
                    {% endif %}
                  </a>

                  <div class="dv-seasonal-specials__product-content">
                    {% if product_title != blank %}
                      <h3 class="dv-seasonal-specials__product-title">{{ product_title }}</h3>
                    {% endif %}
                    <div class="dv-seasonal-specials__product-footer">
                      {% if card_product != blank %}
                        <span class="dv-seasonal-specials__product-price">{{ card_product.price | money }}</span>
                      {% endif %}

                      {% if block.settings.button_label != blank %}
                        {% if block.settings.button_action == 'add_to_cart' and card_variant != blank %}
                          <form method="post" action="{{ routes.cart_add_url }}" class="dv-seasonal-specials__product-form">
                            <input type="hidden" name="id" value="{{ card_variant.id }}">
                            <input type="hidden" name="quantity" value="1">
                            <button
                              type="submit"
                              class="dv-seasonal-specials__product-button"
                              aria-label="{{ block.settings.button_label | escape }} {{ product_title | escape }}"
                              {% unless card_variant.available %}disabled{% endunless %}
                            >
                              {{ block.settings.button_label }}
                            </button>
                          </form>
                        {% else %}
                          <a
                            class="dv-seasonal-specials__product-button"
                            href="{{ product_link | default: routes.all_products_collection_url }}"
                            aria-label="{{ block.settings.button_label | escape }} {{ product_title | escape }}"
                          >
                            {{ block.settings.button_label }}
                          </a>
                        {% endif %}
                      {% endif %}
                    </div>
                  </div>
                </article>
              {% endif %}
              {% endfor %}
            </div>

            {% if section.settings.product_display_mode == 'carousel' and section.settings.show_product_dots and product_card_count > 1 %}
              {% assign product_dot_index = 0 %}
              <div class="dv-seasonal-specials__product-dots" role="tablist" aria-label="Featured product cards">
                {% for block in section.blocks %}
                  {% if block.type == 'side_product' %}
                    <button
                      class="dv-seasonal-specials__product-dot{% if product_dot_index == 0 %} is-active{% endif %}"
                      type="button"
                      data-dv-seasonal-products-dot
                      data-slide-index="{{ product_dot_index }}"
                      aria-label="Show product card {{ product_dot_index | plus: 1 }}"
                      aria-selected="{% if product_dot_index == 0 %}true{% else %}false{% endif %}"
                    ></button>
                    {% assign product_dot_index = product_dot_index | plus: 1 %}
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% else %}
      <p class="dv-seasonal-specials__empty">Add combo and product cards in the theme editor.</p>
    {% endif %}
  </div>
</section>

<style>
  {% render 'dv-gold-home-typography', section_anchor: section_anchor %}
