{% liquid
  assign section_anchor = 'dv-gold-reviews-' | append: section.id
  assign reviews_per_page = section.settings.reviews_per_page
  assign total_reviews = section.blocks.size
  assign section_heading = section.settings.heading | default: 'WORDS FROM OUR CONNOISSEURS'
  assign total_pages = total_reviews | plus: reviews_per_page | minus: 1 | divided_by: reviews_per_page
  if total_pages < 1
    assign total_pages = 1
  endif
%}

{{ 'dv-gold-reviews.js' | asset_url | script_tag }}

<section
  id="{{ section_anchor }}"
  class="dv-reviews color-{{ section.settings.color_scheme }}"
  style="
    --dv-reviews-bg: {{ section.settings.background_color }};
    --dv-reviews-heading: {{ section.settings.heading_color }};
    --dv-reviews-card-bg: {{ section.settings.card_background }};
    --dv-reviews-card-border: {{ section.settings.card_border }};
    --dv-reviews-text: {{ section.settings.text_color }};
    --dv-reviews-accent: {{ section.settings.accent_color }};
    --dv-reviews-max-width: {{ section.settings.max_width }}px;
    --dv-reviews-mobile-padding-top: {{ section.settings.mobile_padding_top }}px;
    --dv-reviews-mobile-padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    --dv-reviews-desktop-padding-top: {{ section.settings.desktop_padding_top }}px;
    --dv-reviews-desktop-padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
  "
  data-review-pagination
  data-review-active-page="1"
  data-review-total-pages="{{ total_pages }}"
>
  <div class="dv-reviews__inner">
    {% if section_heading != blank %}
      <h2 class="dv-reviews__heading">{{ section_heading | escape }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="dv-reviews__subheading">{{ section.settings.subheading | escape }}</p>
    {% endif %}

    <div class="dv-reviews__grid" role="list">
      {% if total_reviews > 0 %}
        {% for block in section.blocks %}
          {% liquid
            assign zero_based_index = forloop.index0
            assign review_page = zero_based_index | divided_by: reviews_per_page | plus: 1
          %}
          <article
            class="dv-reviews__card"
            role="listitem"
            data-review-card
            data-page="{{ review_page }}"
            {% if review_page != 1 %}hidden{% endif %}
            {{ block.shopify_attributes }}
          >
            <div class="dv-reviews__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
              {% for star in (1..5) %}
                <span aria-hidden="true">{% if star <= block.settings.rating %}★{% else %}☆{% endif %}</span>
              {% endfor %}
            </div>

            {% if block.settings.quote != blank %}
              <blockquote class="dv-reviews__quote">{{ block.settings.quote }}</blockquote>
            {% endif %}

            <div class="dv-reviews__author">
              {% if block.settings.author != blank %}
                <span class="dv-reviews__author-name">{{ block.settings.author | escape }}</span>
              {% endif %}
              {% if block.settings.location != blank %}
                <span class="dv-reviews__author-location">{{ block.settings.location | escape }}</span>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      {% else %}
        <p class="dv-reviews__empty">Add review blocks to populate this section.</p>
      {% endif %}
    </div>

    {% if total_pages > 1 %}
      <nav class="dv-reviews__pagination" aria-label="Reviews pages">
        <button class="dv-reviews__pagination-button" type="button" data-review-pagination-previous aria-label="Previous reviews page">
          Previous
        </button>

        <div class="dv-reviews__page-list" aria-label="Review page shortcuts" data-review-page-list>
          {% for page in (1..total_pages) %}
            {% if page <= 3 or page == total_pages %}
              <button
                class="dv-reviews__pagination-button{% if page == 1 %} dv-reviews__pagination-button--active{% endif %}"
                type="button"
                data-review-page-button="{{ page }}"
                aria-label="Reviews page {{ page }}"
                aria-current="{% if page == 1 %}page{% else %}false{% endif %}"
              >
                {{ page }}
              </button>
            {% elsif page == 4 %}
              <span class="dv-reviews__pagination-ellipsis" aria-hidden="true">…</span>
            {% endif %}
          {% endfor %}
        </div>

        <button class="dv-reviews__pagination-button" type="button" data-review-pagination-next aria-label="Next reviews page">
          Next
        </button>
      </nav>
    {% endif %}
  </div>
</section>

<style>
  #{{ section_anchor }} {
    background: var(--dv-reviews-bg);
    color: var(--dv-reviews-text);
    padding-block: var(--dv-reviews-mobile-padding-top) var(--dv-reviews-mobile-padding-bottom);
  }

  #{{ section_anchor }} .dv-reviews__inner {
    width: min(calc(100% - 32px), var(--dv-reviews-max-width));
    margin-inline: auto;
  }

  #{{ section_anchor }} .dv-reviews__heading {
    margin: 0 0 12px;
    color: var(--dv-reviews-heading);
    font-family: var(--font-heading--family);
    font-size: clamp(3.4rem, 9vw, 5.6rem);
    font-weight: 800;
    line-height: 1;
    text-align: center;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .dv-reviews__subheading {
    max-width: 760px;
    margin: 0 auto 32px;
    font-size: clamp(1.6rem, 4vw, 2rem);
    line-height: 1.5;
    text-align: center;
  }

  #{{ section_anchor }} .dv-reviews__grid {
    display: grid;
    gap: 18px;
  }

  #{{ section_anchor }} .dv-reviews__card {
    display: grid;
    gap: 16px;
    padding: 24px;
    border: 1px solid var(--dv-reviews-card-border);
    border-radius: 22px;
    background: var(--dv-reviews-card-bg);
    box-shadow: 0 16px 34px rgba(74, 42, 20, 0.08);
  }

  #{{ section_anchor }} .dv-reviews__card[hidden],
  #{{ section_anchor }} .dv-reviews__card--hidden {
    display: none !important;
  }

  #{{ section_anchor }} .dv-reviews__stars {
    color: var(--dv-reviews-accent);
    font-size: 2rem;
    letter-spacing: 0.08em;
  }

  #{{ section_anchor }} .dv-reviews__quote {
    margin: 0;
    font-size: clamp(1.6rem, 4vw, 1.9rem);
    line-height: 1.55;
  }

  #{{ section_anchor }} .dv-reviews__author {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 10px;
    align-items: center;
    font-size: 1.4rem;
    font-weight: 700;
  }

  #{{ section_anchor }} .dv-reviews__author-location::before {
    content: '•';
    margin-inline-end: 10px;
    color: var(--dv-reviews-accent);
  }

  #{{ section_anchor }} .dv-reviews__pagination {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    justify-content: center;
    margin-block-start: 32px;
  }

  #{{ section_anchor }} .dv-reviews__page-list {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  #{{ section_anchor }} .dv-reviews__pagination-button {
    min-width: 42px;
    min-height: 42px;
    padding: 8px 14px;
    border: 1px solid var(--dv-reviews-card-border);
    border-radius: 999px;
    background: var(--dv-reviews-card-bg);
    color: var(--dv-reviews-text);
    cursor: pointer;
    font: inherit;
    font-weight: 800;
  }

  #{{ section_anchor }} .dv-reviews__pagination-button:hover,
  #{{ section_anchor }} .dv-reviews__pagination-button:focus-visible,
  #{{ section_anchor }} .dv-reviews__pagination-button--active {
    border-color: var(--dv-reviews-accent);
    background: var(--dv-reviews-accent);
    color: var(--dv-reviews-card-bg);
  }

  #{{ section_anchor }} .dv-reviews__pagination-button:disabled {
    cursor: not-allowed;
    opacity: 0.45;
  }

  #{{ section_anchor }} .dv-reviews__pagination-ellipsis {
    padding-inline: 4px;
    font-weight: 800;
  }

  #{{ section_anchor }} .dv-reviews__empty {
    margin: 0;
    text-align: center;
  }

  @media screen and (min-width: 750px) {
    #{{ section_anchor }} {
      padding-block: var(--dv-reviews-desktop-padding-top) var(--dv-reviews-desktop-padding-bottom);
    }

    #{{ section_anchor }} .dv-reviews__inner {
      width: min(calc(100% - 64px), var(--dv-reviews-max-width));
    }

    #{{ section_anchor }} .dv-reviews__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 22px;
    }
  }
</style>

{% schema %}
{
  "name": "DV Gold Reviews",
  "tag": "section",
  "class": "section-dv-gold-reviews",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "WORDS FROM OUR CONNOISSEURS" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Trusted by tea lovers around the world." },
    { "type": "range", "id": "reviews_per_page", "min": 1, "max": 12, "step": 1, "label": "Reviews per page", "default": 3 },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#fbf5ef" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#9b2d32" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#fffaf2" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#f0dfbf" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#191512" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#c99700" },
    { "type": "range", "id": "max_width", "min": 0, "max": 1400, "step": 20, "unit": "px", "label": "Maximum width", "default": 1180 },
    { "type": "range", "id": "mobile_padding_top", "min": 0, "max": 160, "step": 2, "unit": "px", "label": "Mobile padding top", "default": 72 },
    { "type": "range", "id": "mobile_padding_bottom", "min": 0, "max": 160, "step": 2, "unit": "px", "label": "Mobile padding bottom", "default": 80 },
    { "type": "range", "id": "desktop_padding_top", "min": 0, "max": 200, "step": 2, "unit": "px", "label": "Desktop padding top", "default": 88 },
    { "type": "range", "id": "desktop_padding_bottom", "min": 0, "max": 200, "step": 2, "unit": "px", "label": "Desktop padding bottom", "default": 96 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Rating", "default": 5 },
        { "type": "richtext", "id": "quote", "label": "Quote", "default": "<p>Beautiful flavor, fast delivery, and premium packaging.</p>" },
        { "type": "text", "id": "author", "label": "Author", "default": "DV Gold Customer" },
        { "type": "text", "id": "location", "label": "Location", "default": "Verified buyer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DV Gold Reviews",
      "blocks": [
        { "type": "review" },
        { "type": "review", "settings": { "author": "Amara K.", "location": "London" } },
        { "type": "review", "settings": { "author": "Nina P.", "location": "New York" } },
        { "type": "review", "settings": { "author": "Maya S.", "location": "Dubai" } },
        { "type": "review", "settings": { "author": "Priya R.", "location": "Toronto" } },
        { "type": "review", "settings": { "author": "Elena V.", "location": "Paris" } }
      ]
    }
  ]
}
{% endschema %}
