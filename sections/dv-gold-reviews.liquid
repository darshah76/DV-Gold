{% liquid
  assign section_anchor = 'dv-gold-reviews-' | append: section.id
  assign review_count = section.blocks.size
%}

<section
  id="{{ section_anchor }}"
  class="dv-reviews color-{{ section.settings.color_scheme }}"
  style="
    --dv-reviews-bg: {{ section.settings.background_color }};
    --dv-reviews-heading: {{ section.settings.heading_color }};
    --dv-reviews-card-bg: {{ section.settings.card_background }};
    --dv-reviews-card-border: {{ section.settings.card_border }};
    --dv-reviews-text: {{ section.settings.text_color }};
    --dv-reviews-muted: {{ section.settings.muted_text_color }};
    --dv-reviews-gold: {{ section.settings.star_color }};
    --dv-reviews-button-bg: {{ section.settings.button_background }};
    --dv-reviews-button-text: {{ section.settings.button_text_color }};
    --dv-reviews-max-width: {{ section.settings.max_width }}px;
    --dv-reviews-mobile-padding-top: {{ section.settings.mobile_padding_top }}px;
    --dv-reviews-mobile-padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    --dv-reviews-desktop-padding-top: {{ section.settings.desktop_padding_top }}px;
    --dv-reviews-desktop-padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
  "
>
  <div class="dv-reviews__inner">
    <div class="dv-reviews__summary">
      {% if section.settings.heading != blank %}
        <h2 class="dv-reviews__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      <div class="dv-reviews__rating-row" aria-label="{{ section.settings.rating | escape }} out of 5 stars">
        <span class="dv-reviews__rating">{{ section.settings.rating | escape }}</span>
        <span class="dv-reviews__stars" aria-hidden="true">★★★★★</span>
      </div>

      {% if section.settings.review_count_text != blank %}
        <p class="dv-reviews__count">{{ section.settings.review_count_text | escape }}</p>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a class="dv-reviews__button" href="{{ section.settings.button_link | default: '#write-a-review' }}">
          {{ section.settings.button_label | escape }}
        </a>
      {% endif %}
    </div>

    <div class="dv-reviews__list" role="list" aria-label="Customer reviews">
      {% if review_count > 0 %}
        {% for block in section.blocks %}
          {% render 'dv-gold-review-card', block: block, section: section %}
        {% endfor %}
      {% else %}
        {% liquid
          assign fallback_names = 'Ananya Shah|Vikram Patel|Priya Iyer' | split: '|'
          assign fallback_reviews = 'DV Gold has become my first choice for festive gifting. The sweets arrived fresh, beautifully packed, and every bite tasted rich and authentic.|The quality is consistently excellent. From ordering to delivery, everything felt premium and thoughtful — exactly what I expect from DV Gold.|Loved the elegant packaging and the flavour of every mithai. It made our family celebration feel even more special.' | split: '|'
        %}
        {% for fallback_name in fallback_names %}
          {% liquid
            assign fallback_index = forloop.index0
            assign fallback_review = fallback_reviews[fallback_index]
          %}
          <article class="dv-reviews__card" role="listitem">
            <div class="dv-reviews__card-stars" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="dv-reviews__body">{{ fallback_review }}</p>
            <div class="dv-reviews__footer">
              <p class="dv-reviews__author">{{ fallback_name }}</p>
              <p class="dv-reviews__badge">{{ section.settings.verified_badge_text | escape }}</p>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .dv-reviews {
    background: var(--dv-reviews-bg);
    color: var(--dv-reviews-text);
    padding-block: var(--dv-reviews-mobile-padding-top) var(--dv-reviews-mobile-padding-bottom);
  }

  .dv-reviews__inner {
    width: min(100% - 28px, var(--dv-reviews-max-width));
    margin-inline: auto;
  }

  .dv-reviews__summary {
    display: grid;
    justify-items: center;
    text-align: center;
    margin-inline: auto;
    max-width: 287px;
  }

  .dv-reviews__heading {
    margin: 0 0 13px;
    color: var(--dv-reviews-heading);
    font-family: var(--font-heading--family);
    font-size: clamp(2.75rem, 11vw, 4rem);
    font-weight: 800;
    letter-spacing: 0.045em;
    line-height: 0.98;
    text-transform: uppercase;
  }

  .dv-reviews__rating-row {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-block-end: 5px;
  }

  .dv-reviews__rating {
    color: var(--dv-reviews-text);
    font-size: 1.55rem;
    font-weight: 700;
    line-height: 1;
  }

  .dv-reviews__stars,
  .dv-reviews__card-stars {
    color: var(--dv-reviews-gold);
    font-size: 1.45rem;
    letter-spacing: 0.08em;
    line-height: 1;
  }

  .dv-reviews__count {
    margin: 0 0 13px;
    color: var(--dv-reviews-muted);
    font-size: 1.22rem;
    font-weight: 500;
    line-height: 1.3;
  }

  .dv-reviews__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 126px;
    min-height: 36px;
    padding: 10px 18px;
    border-radius: 999px;
    background: var(--dv-reviews-button-bg);
    color: var(--dv-reviews-button-text);
    font-size: 1.18rem;
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    transition: transform 160ms ease, opacity 160ms ease;
  }

  .dv-reviews__button:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  .dv-reviews__list {
    display: grid;
    gap: 14px;
    margin-block-start: 26px;
  }

  .dv-reviews__card {
    display: grid;
    gap: 12px;
    min-height: 164px;
    padding: 18px 18px 16px;
    border: 1px solid var(--dv-reviews-card-border);
    border-radius: 18px;
    background: var(--dv-reviews-card-bg);
    box-shadow: 0 12px 26px rgba(84, 48, 24, 0.06);
  }

  .dv-reviews__card-stars {
    font-size: 1.25rem;
    letter-spacing: 0.05em;
  }

  .dv-reviews__body {
    margin: 0;
    color: var(--dv-reviews-text);
    font-size: 1.28rem;
    font-weight: 500;
    line-height: 1.48;
  }

  .dv-reviews__footer {
    align-self: end;
    display: grid;
    gap: 4px;
    margin-block-start: 2px;
  }

  .dv-reviews__author {
    margin: 0;
    color: var(--dv-reviews-text);
    font-size: 1.32rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .dv-reviews__badge {
    margin: 0;
    color: var(--dv-reviews-muted);
    font-size: 0.96rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  @media screen and (min-width: 750px) {
    .dv-reviews {
      padding-block: var(--dv-reviews-desktop-padding-top) var(--dv-reviews-desktop-padding-bottom);
    }

    .dv-reviews__inner {
      width: min(100% - 64px, var(--dv-reviews-max-width));
    }

    .dv-reviews__summary {
      max-width: 760px;
    }

    .dv-reviews__heading {
      margin-block-end: 18px;
      font-size: clamp(4.8rem, 5vw, 6.8rem);
      line-height: 1.02;
    }

    .dv-reviews__rating-row {
      gap: 10px;
    }

    .dv-reviews__rating {
      font-size: 1.8rem;
    }

    .dv-reviews__stars {
      font-size: 1.7rem;
    }

    .dv-reviews__count {
      font-size: 1.35rem;
      margin-block-end: 16px;
    }

    .dv-reviews__button {
      min-height: 40px;
      padding-inline: 22px;
      font-size: 1.28rem;
    }

    .dv-reviews__list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
      margin-block-start: 34px;
    }

    .dv-reviews__card {
      min-height: 202px;
      padding: 22px 22px 18px;
      border-radius: 22px;
    }

    .dv-reviews__body {
      font-size: 1.42rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "DV Gold Reviews",
  "tag": "section",
  "class": "section-dv-gold-reviews",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "WORDS FROM OUR CONNOISSEURS" },
    { "type": "text", "id": "rating", "label": "Rating", "default": "4.86" },
    { "type": "text", "id": "review_count_text", "label": "Review count text", "default": "Based on 76 Reviews" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Write a Review" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "text", "id": "verified_badge_text", "label": "Verified badge text", "default": "VERIFIED BUYER" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#fbf4ea" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#9b2d32" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#fffaf2" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#f1dfbc" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#201612" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text color", "default": "#6f5b4c" },
    { "type": "color", "id": "star_color", "label": "Star color", "default": "#d2a21c" },
    { "type": "color", "id": "button_background", "label": "Button background", "default": "#9b2d32" },
    { "type": "color", "id": "button_text_color", "label": "Button text color", "default": "#fff9ef" },
    { "type": "range", "id": "max_width", "min": 287, "max": 1400, "step": 7, "unit": "px", "label": "Maximum width", "default": 917 },
    { "type": "range", "id": "mobile_padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Mobile padding top", "default": 56 },
    { "type": "range", "id": "mobile_padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Mobile padding bottom", "default": 64 },
    { "type": "range", "id": "desktop_padding_top", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Desktop padding top", "default": 80 },
    { "type": "range", "id": "desktop_padding_bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Desktop padding bottom", "default": 88 }
