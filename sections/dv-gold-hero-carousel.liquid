{% liquid
  assign section_id = 'dv-gold-hero-' | append: section.id
  assign slide_count = section.blocks.size
  assign button_link = section.settings.button_link
  if button_link == blank and section.settings.button_product != blank
    assign button_link = section.settings.button_product.url
  endif
%}

<section
  id="{{ section_id }}"
  class="dv-gold-hero color-{{ section.settings.color_scheme }}"
  data-dv-gold-hero
  aria-label="{{ section.settings.accessibility_label | escape }}"
  style="
    --dv-hero-mobile-height: {{ section.settings.mobile_height }}px;
    --dv-hero-desktop-height: {{ section.settings.desktop_height }}px;
    --dv-hero-button-bottom-mobile: {{ section.settings.button_bottom_mobile }}%;
    --dv-hero-button-bottom-desktop: {{ section.settings.button_bottom_desktop }}%;
    --dv-hero-dots-bottom: {{ section.settings.dots_bottom }}px;
  "
>
  <div class="dv-gold-hero__viewport">
    <div class="dv-gold-hero__track" data-dv-gold-hero-track>
      {%- if slide_count > 0 -%}
        {%- for block in section.blocks -%}
          {% liquid
            assign desktop_image = block.settings.image
            assign mobile_image = block.settings.mobile_image
            if mobile_image == blank
              assign mobile_image = desktop_image
            endif
          %}
          <div
            class="dv-gold-hero__slide{% if forloop.first %} is-active{% endif %}"
            data-dv-gold-hero-slide
            role="group"
            aria-roledescription="slide"
            aria-label="{{ forloop.index }} of {{ slide_count }}"
            {{ block.shopify_attributes }}
          >
            {%- if desktop_image != blank -%}
              <picture class="dv-gold-hero__picture">
                {%- if mobile_image != blank -%}
                  <source
                    media="(max-width: 749px)"
                    srcset="{{ mobile_image | image_url: width: 375 }} 375w, {{ mobile_image | image_url: width: 550 }} 550w, {{ mobile_image | image_url: width: 750 }} 750w, {{ mobile_image | image_url: width: 990 }} 990w"
                    sizes="100vw"
                  >
                {%- endif -%}
                {{
                  desktop_image
                  | image_url: width: 2400
                  | image_tag:
                    class: 'dv-gold-hero__image',
                    widths: '750, 990, 1200, 1500, 1800, 2400',
                    sizes: '100vw',
                    loading: 'eager',
                    fetchpriority: 'high',
                    alt: block.settings.image_alt
                }}
              </picture>
            {%- else -%}
              <div class="dv-gold-hero__placeholder">
                {{ 'hero-apparel-1' | placeholder_svg_tag: 'dv-gold-hero__placeholder-svg' }}
                <p>{{ 'sections.slideshow.name' | t | default: 'Add a hero image' }}</p>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="dv-gold-hero__slide is-active">
          <div class="dv-gold-hero__placeholder">
            {{ 'hero-apparel-1' | placeholder_svg_tag: 'dv-gold-hero__placeholder-svg' }}
            <p>Add carousel slides in the theme editor.</p>
          </div>
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.show_button and section.settings.button_label != blank -%}
      <a
        class="dv-gold-hero__button"
        href="{{ button_link | default: routes.all_products_collection_url }}"
        {% if section.settings.open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
      >
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}

    {%- if slide_count > 1 and section.settings.show_dots -%}
      <div class="dv-gold-hero__dots" role="tablist" aria-label="Hero carousel slides">
        {%- for block in section.blocks -%}
          <button
            class="dv-gold-hero__dot{% if forloop.first %} is-active{% endif %}"
            type="button"
            data-dv-gold-hero-dot
            aria-label="Go to slide {{ forloop.index }}"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .dv-gold-hero {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .dv-gold-hero__viewport {
    height: var(--dv-hero-mobile-height);
    position: relative;
    overflow: hidden;
  }

  .dv-gold-hero__track {
    display: flex;
    height: 100%;
    transition: transform 0.45s ease;
    will-change: transform;
  }

  .dv-gold-hero__slide {
    flex: 0 0 100%;
    height: var(--dv-hero-mobile-height);
    position: relative;
  }

  .dv-gold-hero__picture,
  .dv-gold-hero__image {
    display: block;
    height: 100%;
    width: 100%;
  }

  .dv-gold-hero__image {
    object-fit: cover;
    object-position: center;
  }

  .dv-gold-hero__placeholder {
    align-items: center;
    background: linear-gradient(180deg, #f7d49d 0%, #fff0d7 62%, #a6532d 100%);
    color: #7a2f17;
    display: flex;
    flex-direction: column;
    font-weight: 700;
    gap: 1rem;
    height: 100%;
    justify-content: center;
    min-height: var(--dv-hero-mobile-height);
    text-align: center;
  }

  .dv-gold-hero__placeholder-svg {
    max-width: 28rem;
    width: 70%;
  }

  .dv-gold-hero__button {
    background: #d7e7af;
    border: 1px solid rgba(71, 52, 21, 0.55);
    border-radius: 0.55rem;
    bottom: var(--dv-hero-button-bottom-mobile);
    box-shadow: 0 0.45rem 0.8rem rgba(64, 30, 17, 0.35);
    color: #80301c;
    font-family: var(--font-body--family);
    font-size: clamp(1.2rem, 4.8vw, 1.8rem);
    font-weight: 600;
    text-transform: uppercase;
    left: 50%;
    line-height: 1;
    padding: 0.55em 0.95em;
    position: absolute;
    text-decoration: none;
    transform: translateX(-50%);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    white-space: nowrap;
    z-index: 2;
  }

  .dv-gold-hero__button:hover,
  .dv-gold-hero__button:focus-visible {
    box-shadow: 0 0.55rem 1rem rgba(64, 30, 17, 0.45);
    transform: translateX(-50%) translateY(-2px);
  }

  .dv-gold-hero__dots {
    align-items: center;
    bottom: var(--dv-hero-dots-bottom);
    display: flex;
    gap: 0.25rem;
    justify-content: center;
    left: 50%;
    position: absolute;
    transform: translateX(-50%);
    z-index: 2;
  }

  .dv-gold-hero__dot {
    appearance: none;
    background: rgba(255, 255, 255, 0.72);
    border: 0;
    border-radius: 50%;
    cursor: pointer;
    height: 0.62rem;
    padding: 0;
    width: 0.62rem;
  }

  .dv-gold-hero__dot.is-active {
    background: #ffffff;
    transform: scale(1.12);
  }

  @media screen and (min-width: 750px) {
    .dv-gold-hero__viewport,
    .dv-gold-hero__slide,
    .dv-gold-hero__placeholder {
      height: var(--dv-hero-desktop-height);
    }

    .dv-gold-hero__button {
      bottom: var(--dv-hero-button-bottom-desktop);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dv-gold-hero__track,
    .dv-gold-hero__button {
      transition: none;
    }
  }
{% endstylesheet %}

<script>
  (() => {
    const initHero = (section) => {
      const track = section.querySelector('[data-dv-gold-hero-track]');
      const slides = Array.from(section.querySelectorAll('[data-dv-gold-hero-slide]'));
      const dots = Array.from(section.querySelectorAll('[data-dv-gold-hero-dot]'));
      if (!track || slides.length <= 1) return;

      let currentIndex = 0;
      let timer;
      const autoplay = section.dataset.autoplay === 'true';
      const interval = Number(section.dataset.interval || 5000);

      const goToSlide = (index) => {
        currentIndex = (index + slides.length) % slides.length;
        track.style.transform = `translateX(-${currentIndex * 100}%)`;
        slides.forEach((slide, slideIndex) => slide.classList.toggle('is-active', slideIndex === currentIndex));
        dots.forEach((dot, dotIndex) => {
          dot.classList.toggle('is-active', dotIndex === currentIndex);
          dot.setAttribute('aria-selected', dotIndex === currentIndex ? 'true' : 'false');
        });
      };

      const start = () => {
        if (!autoplay) return;
        window.clearInterval(timer);
        timer = window.setInterval(() => goToSlide(currentIndex + 1), interval);
      };

      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          goToSlide(index);
          start();
        });
      });

      start();
    };

    document.querySelectorAll('[data-dv-gold-hero]').forEach((section) => {
      section.dataset.autoplay = '{{ section.settings.autoplay }}';
      section.dataset.interval = '{{ section.settings.autoplay_speed | times: 1000 }}';
      initHero(section);
    });
  })();
</script>

{% schema %}
{
  "name": "DV Gold hero carousel",
  "tag": "section",
  "class": "section-dv-gold-hero-carousel",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "Accessibility label",
      "default": "Featured promotion"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height",
      "min": 420,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 680
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop height",
      "min": 420,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "default": 760
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show shop button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "product",
      "id": "button_product",
      "label": "Button product"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link override"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open button in a new tab",
      "default": false
    },
    {
      "type": "range",
      "id": "button_bottom_mobile",
      "label": "Button position from bottom on mobile",
      "min": 4,
      "max": 40,
      "step": 1,
      "unit": "%",
      "default": 9
    },
    {
      "type": "range",
      "id": "button_bottom_desktop",
      "label": "Button position from bottom on desktop",
      "min": 4,
      "max": 40,
      "step": 1,
      "unit": "%",
      "default": 10
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show carousel dots",
      "default": true
    },
    {
      "type": "range",
      "id": "dots_bottom",
      "label": "Dots position from bottom",
      "min": 8,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text",
          "default": "DV Gold tea hero banner"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DV Gold hero carousel",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
