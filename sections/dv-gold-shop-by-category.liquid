{% liquid
  assign section_anchor = 'dv-gold-shop-by-category-' | append: section.id
%}

<section
  id="{{ section_anchor }}"
  class="dv-category dv-content-section color-{{ section.settings.color_scheme }}"
  style="
    --dv-category-bg: {{ section.settings.background_color }};
    --dv-category-heading: {{ section.settings.heading_color }};
    --dv-category-connector-color: {{ section.settings.connector_color }};
    --dv-category-underline-color: {{ section.settings.underline_color }};
    --dv-category-connector-thickness: {{ section.settings.connector_thickness }}px;
    --dv-category-underline-width: {{ section.settings.underline_width }}px;
    --dv-category-underline-thickness: {{ section.settings.underline_thickness }}px;
    --dv-category-card-bg: {{ section.settings.card_background }};
    --dv-category-button-bg: {{ section.settings.button_background }};
    --dv-category-button-text: {{ section.settings.button_text_color }};
    --dv-category-max-width: {{ section.settings.max_width }}px;
    --dv-category-mobile-padding-top: {{ section.settings.mobile_padding_top }}px;
    --dv-category-mobile-padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    --dv-category-desktop-padding-top: {{ section.settings.desktop_padding_top }}px;
    --dv-category-desktop-padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
  "
>
  <div class="dv-category__inner dv-section-container">
    {% if section.settings.heading != blank %}
      <h2 class="dv-category__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="dv-category__list" role="list">
      {% for block in section.blocks %}
        {% liquid
          assign category_collection = block.settings.collection
          assign category_title = block.settings.title | default: category_collection.title
          assign category_link = block.settings.link
          if category_link == blank and category_collection != blank
            assign category_link = category_collection.url
          endif
          if category_link == blank
            assign category_link = '#'
          endif
          assign category_image = block.settings.image
          if category_image == blank and category_collection != blank
            assign category_image = category_collection.featured_image
            if category_image == blank
              assign category_image = category_collection.image
            endif
          endif
          assign category_aria_label = category_title | default: block.settings.button_label
          assign category_image_alt = category_image.alt | default: category_title
          assign rotation = block.settings.card_rotation | default: 0
          assign block_card_bg = block.settings.card_background
          if block_card_bg == blank or block_card_bg == 'rgba(0,0,0,0)'
            assign block_card_bg = section.settings.card_background
          endif
        %}

        <div class="dv-category__item" role="listitem" {{ block.shopify_attributes }}>
          <div
            class="dv-category__card-shell"
            style="--dv-category-rotation: {{ rotation }}deg; --dv-category-block-card-bg: {{ block_card_bg }};"
          >
            <a
              class="dv-category__card"
              href="{{ category_link }}"
              {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
              aria-label="{{ category_aria_label | escape }}"
            >
              {% if category_image != blank %}
                {{
                  category_image
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    widths: '320, 480, 640, 800, 1000, 1200',
                    sizes: '(min-width: 990px) 520px, 86vw',
                    class: 'dv-category__image',
                    alt: category_image_alt
                }}
              {% else %}
                <div class="dv-category__placeholder" aria-hidden="true">
                  {{ 'image' | placeholder_svg_tag: 'dv-category__placeholder-svg' }}
                </div>
              {% endif %}

              {% if block.settings.button_label != blank %}
                <span class="dv-category__button">{{ block.settings.button_label }}</span>
              {% endif %}
            </a>
          </div>

          {% if category_title != blank %}
            <h3 class="dv-category__title">{{ category_title }}</h3>
          {% endif %}

          {% if section.settings.show_connectors and forloop.last == false %}
            <div class="dv-category__connector" aria-hidden="true"></div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #{{ section_anchor }} {
    background: var(--dv-category-bg);
    padding-block: var(--dv-category-mobile-padding-top) var(--dv-category-mobile-padding-bottom);
    overflow: hidden;
  }

  #{{ section_anchor }} .dv-category__inner {
    width: min(100% - 32px, var(--dv-category-max-width));
    margin-inline: auto;
  }

  #{{ section_anchor }} .dv-category__heading {
    margin: 0 0 clamp(46px, 12vw, 92px);
    color: var(--dv-category-heading);
    font-family: var(--font-heading--family);
    font-size: var(--dv-section-heading-size);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    text-align: center;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .dv-category__list {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #{{ section_anchor }} .dv-category__item {
    position: relative;
    width: min(100%, 720px);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #{{ section_anchor }} .dv-category__card-shell {
    width: min(100%, 640px);
    transform: rotate(var(--dv-category-rotation));
    filter: drop-shadow(0 7px 10px rgba(45, 28, 14, 0.13));
  }

  #{{ section_anchor }} .dv-category__card {
    position: relative;
    display: block;
    aspect-ratio: 1.52 / 1;
    padding: clamp(10px, 2vw, 16px);
    background: var(--dv-category-block-card-bg);
    border: 1px solid rgba(255, 255, 255, 0.75);
    border-radius: 2px;
    box-shadow: 0 0 0 1px rgba(117, 87, 45, 0.04), 0 2px 4px rgba(45, 28, 14, 0.08);
    text-decoration: none;
  }

  #{{ section_anchor }} .dv-category__image,
  #{{ section_anchor }} .dv-category__placeholder {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  #{{ section_anchor }} .dv-category__placeholder {
    background: rgba(255, 255, 255, 0.34);
  }

  #{{ section_anchor }} .dv-category__placeholder-svg {
    width: 100%;
    height: 100%;
    opacity: 0.35;
  }

  #{{ section_anchor }} .dv-category__button {
    position: absolute;
    left: 50%;
    bottom: clamp(10px, 2.5vw, 18px);
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 34px;
    padding: 7px 15px 6px;
    border-radius: 7px;
    background: var(--dv-category-button-bg);
    color: var(--dv-category-button-text);
    font-size: clamp(1.3rem, 3vw, 1.7rem);
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
  }

  #{{ section_anchor }} .dv-category__title {
    margin: clamp(22px, 5vw, 34px) 0 8px;
    color: var(--dv-category-heading);
    font-family: var(--font-heading--family);
    font-size: clamp(1.9rem, 4.8vw, 2.5rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.18em;
    text-align: center;
    text-transform: uppercase;
  }

  {% if section.settings.show_underlines %}
  #{{ section_anchor }} .dv-category__title::after {
    content: '';
    display: block;
    width: var(--dv-category-underline-width);
    height: var(--dv-category-underline-thickness);
    margin: 10px auto 0;
    background: var(--dv-category-underline-color);
  }
  {% endif %}

  #{{ section_anchor }} .dv-category__connector {
    width: var(--dv-category-connector-thickness);
    height: clamp(92px, 18vw, 150px);
    margin: -2px auto clamp(34px, 9vw, 66px);
    {% if section.settings.connector_style == 'solid' %}
      background: var(--dv-category-connector-color);
    {% else %}
    background-image: repeating-linear-gradient(
      to bottom,
      var(--dv-category-connector-color) 0,
      var(--dv-category-connector-color) {% if section.settings.connector_style == 'dotted' %}8px{% else %}25px{% endif %},
      transparent {% if section.settings.connector_style == 'dotted' %}8px{% else %}25px{% endif %},
      transparent {% if section.settings.connector_style == 'dotted' %}18px{% else %}51px{% endif %}
    );
    {% endif %}
  }

  @media screen and (min-width: 750px) {
    #{{ section_anchor }} {
      padding-block: var(--dv-category-desktop-padding-top) var(--dv-category-desktop-padding-bottom);
    }

    #{{ section_anchor }} .dv-category__inner {
      width: min(100% - 64px, var(--dv-category-max-width));
    }

    #{{ section_anchor }} .dv-category__list {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      align-items: start;
      column-gap: clamp(28px, 4vw, 64px);
      row-gap: clamp(52px, 7vw, 88px);
    }

    #{{ section_anchor }} .dv-category__item,
    #{{ section_anchor }} .dv-category__card-shell {
      width: 100%;
    }

    #{{ section_anchor }} .dv-category__card {
      padding: clamp(6px, 1vw, 12px);
    }

    #{{ section_anchor }} .dv-category__button {
      min-height: 28px;
      padding: 6px 10px 5px;
      font-size: clamp(1rem, 1.25vw, 1.5rem);
    }

    #{{ section_anchor }} .dv-category__title {
      margin-top: clamp(18px, 2.5vw, 28px);
      font-size: clamp(1.4rem, 2vw, 2.2rem);
    }

    #{{ section_anchor }} .dv-category__connector {
      position: absolute;
      top: 50%;
      left: calc(100% + (clamp(28px, 4vw, 64px) / 2));
      width: clamp(28px, 4vw, 64px);
      height: var(--dv-category-connector-thickness);
      margin: 0;
      transform: translate(-50%, -50%);
      {% if section.settings.connector_style == 'solid' %}
        background: var(--dv-category-connector-color);
      {% else %}
      background-image: repeating-linear-gradient(
        to right,
        var(--dv-category-connector-color) 0,
        var(--dv-category-connector-color) {% if section.settings.connector_style == 'dotted' %}8px{% else %}25px{% endif %},
        transparent {% if section.settings.connector_style == 'dotted' %}8px{% else %}25px{% endif %},
        transparent {% if section.settings.connector_style == 'dotted' %}18px{% else %}51px{% endif %}
      );
      {% endif %}
    }

    #{{ section_anchor }} .dv-category__item:nth-child(4n) .dv-category__connector {
      display: none;
    }
  }

  @media screen and (min-width: 990px) {
    #{{ section_anchor }} .dv-category__heading {
      text-align: left;
      margin-left: max(0px, calc((var(--dv-category-max-width) - 720px) / 2));
    }
  }
</style>

{% schema %}
{
  "name": "DV Gold shop by category",
  "tag": "section",
  "class": "section-dv-gold-shop-by-category",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "SHOP BY CATEGORY" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#fbf5ee" },
    { "type": "color", "id": "heading_color", "label": "Heading and category text color", "default": "#9b2d32" },
    { "type": "header", "content": "Connector" },
    { "type": "checkbox", "id": "show_connectors", "label": "Show connectors", "default": true },
    { "type": "color", "id": "connector_color", "label": "Connector color", "default": "#c89100" },
    { "type": "select", "id": "connector_style", "label": "Connector style", "default": "dashed", "options": [{ "value": "solid", "label": "Solid" }, { "value": "dashed", "label": "Dashed" }, { "value": "dotted", "label": "Dotted" }] },
    { "type": "range", "id": "connector_thickness", "label": "Connector thickness", "min": 2, "max": 16, "step": 1, "unit": "px", "default": 13 },
    { "type": "header", "content": "Category underline" },
    { "type": "checkbox", "id": "show_underlines", "label": "Show underlines", "default": true },
    { "type": "color", "id": "underline_color", "label": "Underline color", "default": "#c89100" },
    { "type": "range", "id": "underline_width", "label": "Underline width", "min": 20, "max": 160, "step": 2, "unit": "px", "default": 86 },
    { "type": "range", "id": "underline_thickness", "label": "Underline thickness", "min": 1, "max": 8, "step": 1, "unit": "px", "default": 2 },
    { "type": "color", "id": "card_background", "label": "Default card background", "default": "#fbefd9" },
    { "type": "color", "id": "button_background", "label": "Button background", "default": "#c99739" },
    { "type": "color", "id": "button_text_color", "label": "Button text color", "default": "#ffffff" },
    { "type": "range", "id": "max_width", "label": "Content max width", "min": 640, "max": 1400, "step": 20, "unit": "px", "default": 760 },
    { "type": "range", "id": "mobile_padding_top", "label": "Mobile top padding", "min": 0, "max": 180, "step": 4, "unit": "px", "default": 120 },
    { "type": "range", "id": "mobile_padding_bottom", "label": "Mobile bottom padding", "min": 0, "max": 180, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "desktop_padding_top", "label": "Desktop top padding", "min": 0, "max": 220, "step": 4, "unit": "px", "default": 120 },
    { "type": "range", "id": "desktop_padding_bottom", "label": "Desktop bottom padding", "min": 0, "max": 220, "step": 4, "unit": "px", "default": 96 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "title", "label": "Category name", "default": "TEA" },
        { "type": "text", "id": "button_label", "label": "Button text", "default": "SHOP NOW" },
        { "type": "url", "id": "link", "label": "Button and card link" },
        { "type": "checkbox", "id": "open_in_new_tab", "label": "Open link in new tab", "default": false },
        { "type": "range", "id": "card_rotation", "label": "Card rotation", "min": -8, "max": 8, "step": 1, "unit": "deg", "default": -2 },
        { "type": "color", "id": "card_background", "label": "Card background override", "default": "#fbefd9" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DV Gold shop by category",
      "blocks": [
        { "type": "category", "settings": { "title": "TEA", "card_rotation": 2 } },
        { "type": "category", "settings": { "title": "SPICE", "card_rotation": -4 } },
        { "type": "category", "settings": { "title": "POWDER", "card_rotation": 3 } }
      ]
    }
  ]
}
{% endschema %}
