        { "type": "textarea", "id": "quote", "label": "Quote", "default": "The aroma of the DV Gold Tea is unparalleled. It has become a non-negotiable staple in my morning ritual. Truly artisanal quality." },
        { "type": "text", "id": "author", "label": "Author", "default": "ANANYA SHAH" },
        { "type": "text", "id": "verified_label", "label": "Verified label", "default": "VERIFIED BUYER" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DV Gold reviews",
      "blocks": [
        { "type": "review", "settings": { "quote": "The aroma of the DV Gold Tea is unparalleled. It has become a non-negotiable staple in my morning ritual. Truly artisanal quality.", "author": "ANANYA SHAH", "verified_label": "VERIFIED BUYER" } },
        { "type": "review", "settings": { "quote": "The heritage spices reminded me of my grandmother's kitchen. You can tell they are small-batch and fresh. Excellent service too.", "author": "VIKRAM PATEL", "verified_label": "VERIFIED BUYER" } },
        { "type": "review", "settings": { "quote": "I've tried many luxury tea brands, but The Sensory Archive's commitment to purity is evident from the first sip. Highly recommended.", "author": "PRIYA IYER", "verified_label": "VERIFIED BUYER" } }
      ]
    }
  ]
}
