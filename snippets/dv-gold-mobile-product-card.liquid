{% liquid
  assign product_image = product.featured_image
  assign selected_variant = product.selected_or_first_available_variant
%}

<article class="dv-mobile-product-card">
  <a class="dv-mobile-product-card__image-link" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
    {% if product_image != blank %}
      {{
        product_image
        | image_url: width: 520
        | image_tag:
          loading: 'lazy',
          widths: '180, 260, 360, 520',
          sizes: '(min-width: 990px) calc((min(100vw, 1180px) - 200px) / 4), (min-width: 750px) calc((100vw - 92px) / 3), calc((100vw - 48px) / 2)',
          class: 'dv-mobile-product-card__image',
          alt: product_image.alt
      }}
    {% else %}
      {{ 'product-1' | placeholder_svg_tag: 'dv-mobile-product-card__placeholder' }}
    {% endif %}
  </a>

  <div class="dv-mobile-product-card__content">
    <h3 class="dv-mobile-product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    <p class="dv-mobile-product-card__price">
      {% if product.price_varies %}
        From {{ product.price_min | money }}
      {% else %}
        {{ selected_variant.price | money }}
      {% endif %}
    </p>
  </div>
</article>
