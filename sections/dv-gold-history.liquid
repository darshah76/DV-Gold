{% liquid
  assign section_anchor = 'dv-gold-history-' | append: section.id
%}

<section
  id="{{ section_anchor }}"
  class="dv-history dv-content-section color-{{ section.settings.color_scheme }}"
>
  <div class="dv-history__inner dv-section-container">
    {% if section.settings.heading != blank %}
      <h2 class="dv-history__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="dv-history__content">
      <div class="dv-history__media-card">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1400 | image_tag: class: 'dv-history__image', loading: 'lazy', sizes: '(min-width: 990px) 50vw, 100vw', widths: '375, 550, 750, 990, 1200, 1400', alt: section.settings.image_alt }}
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'dv-history__placeholder' }}
        {% endif %}
      </div>

      {% if section.settings.text != blank %}
        <div class="dv-history__text rte">
          {{ section.settings.text }}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #{{ section_anchor }} {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-block: {{ section.settings.mobile_padding_top }}px {{ section.settings.mobile_padding_bottom }}px;
  }

  #{{ section_anchor }} .dv-history__inner {
    width: min(100% - 24px, {{ section.settings.max_width }}px);
    margin-inline: auto;
  }

  #{{ section_anchor }} .dv-history__heading {
    margin: 0 0 26px;
    color: {{ section.settings.heading_color }};
    font-family: var(--font-heading--family);
    font-size: var(--dv-section-heading-size);
    font-weight: 700;
    line-height: 1;
    text-align: center;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .dv-history__content {
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: center;
  }

  #{{ section_anchor }} .dv-history__media-card {
    width: 100%;
    overflow: hidden;
    border: 1px solid {{ section.settings.image_border_color }};
    border-radius: {{ section.settings.image_radius }}px;
    background: {{ section.settings.image_background }};
    box-shadow: 0 2px 7px rgba(78, 45, 20, 0.16);
  }

  #{{ section_anchor }} .dv-history__image,
  #{{ section_anchor }} .dv-history__placeholder {
    display: block;
    width: 100%;
    height: auto;
  }

  #{{ section_anchor }} .dv-history__text {
    max-width: 44rem;
    color: {{ section.settings.text_color }};
    font-size: clamp(1.8rem, 4.8vw, 2.2rem);
    line-height: 1.25;
    text-align: center;
  }

  #{{ section_anchor }} .dv-history__text > * {
    margin-block: 0 1.6em;
  }

  #{{ section_anchor }} .dv-history__text > *:last-child {
    margin-block-end: 0;
  }

  @media screen and (min-width: 990px) {
    #{{ section_anchor }} {
      padding-block: {{ section.settings.desktop_padding_top }}px {{ section.settings.desktop_padding_bottom }}px;
    }

    #{{ section_anchor }} .dv-history__inner {
      width: min(100% - 64px, {{ section.settings.max_width }}px);
    }

    #{{ section_anchor }} .dv-history__heading {
      margin-block-end: 40px;
    }

    #{{ section_anchor }} .dv-history__content {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
      gap: clamp(40px, 6vw, 84px);
      align-items: center;
    }

    #{{ section_anchor }} .dv-history__text {
      max-width: none;
      font-size: clamp(2rem, 1.45vw, 2.6rem);
      text-align: left;
    }
  }
</style>

{% schema %}
{
  "name": "DV Gold history",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "THE DV HISTORY" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "image_alt", "label": "Image alt text", "default": "DV Groups history photograph" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>DV Groups represents a legacy built on trust, quality, and consistency. With roots dating back to 1957, the brand has grown from traditional trading organization into a brand of choice in premium food products.</p><p>Our philosophy is simple—deliver authentic products that preserve their natural essence while meeting the evolving needs of today’s consumers.</p>" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#fbf5ee" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#9b2d32" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#191512" },
    { "type": "color", "id": "image_background", "label": "Image background", "default": "#fffaf2" },
    { "type": "color", "id": "image_border_color", "label": "Image border", "default": "#f0dfbf" },
    { "type": "range", "id": "image_radius", "label": "Image corner radius", "min": 0, "max": 28, "step": 1, "unit": "px", "default": 10 },
    { "type": "range", "id": "max_width", "label": "Content max width", "min": 720, "max": 1600, "step": 20, "unit": "px", "default": 1180 },
    { "type": "range", "id": "mobile_padding_top", "label": "Mobile padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "mobile_padding_bottom", "label": "Mobile padding bottom", "min": 0, "max": 140, "step": 4, "unit": "px", "default": 84 },
    { "type": "range", "id": "desktop_padding_top", "label": "Desktop padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "desktop_padding_bottom", "label": "Desktop padding bottom", "min": 0, "max": 180, "step": 4, "unit": "px", "default": 104 }
  ],
  "presets": [
    { "name": "DV Gold history" }
  ]
}
{% endschema %}
