{% liquid
  assign section_anchor = 'dv-gold-promise-' | append: section.id
%}

<section
  id="{{ section_anchor }}"
  class="dv-promise dv-content-section color-{{ section.settings.color_scheme }}"
  style="
    --dv-promise-bg: {{ section.settings.background_color }};
    --dv-promise-heading: {{ section.settings.heading_color }};
    --dv-promise-text: {{ section.settings.text_color }};
    --dv-promise-muted: {{ section.settings.body_color }};
    --dv-promise-accent: {{ section.settings.accent_color }};
    --dv-promise-icon-bg: {{ section.settings.icon_background }};
    --dv-promise-icon-border: {{ section.settings.icon_border_color }};
    --dv-promise-max-width: {{ section.settings.max_width }}px;
    --dv-promise-mobile-padding-top: {{ section.settings.mobile_padding_top }}px;
    --dv-promise-mobile-padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    --dv-promise-desktop-padding-top: {{ section.settings.desktop_padding_top }}px;
    --dv-promise-desktop-padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
  "
>
  <div class="dv-promise__inner dv-section-container">
    {% if section.settings.heading != blank %}
      <div class="dv-promise__heading-wrap">
        <h2 class="dv-promise__heading">{{ section.settings.heading }}</h2>
        {% if section.settings.show_heading_accent %}
          <span class="dv-promise__heading-accent" aria-hidden="true"></span>
        {% endif %}
      </div>
    {% endif %}

    {% if section.settings.text != blank %}
      <div class="dv-promise__intro rte">{{ section.settings.text }}</div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="dv-promise__grid" role="list">
        {% for block in section.blocks %}
          <article class="dv-promise__item" role="listitem" {{ block.shopify_attributes }}>
            <div class="dv-promise__icon" aria-hidden="true">
              {% if block.settings.icon_image != blank %}
                {{
                  block.settings.icon_image
                  | image_url: width: 96
                  | image_tag:
                    loading: 'lazy',
                    widths: '48, 72, 96',
                    sizes: '48px',
                    class: 'dv-promise__icon-image',
                    alt: block.settings.icon_image.alt
                }}
              {% else %}
                {% case block.settings.icon %}
                  {% when 'sanitized' %}
                    <svg viewBox="0 0 24 24" fill="none" focusable="false"><path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M7 11h10v8H7z" stroke="currentColor" stroke-width="1.8"/><path d="M12 14v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M18.6 6.5l1.2-1.9 1.2 1.9 1.9 1.2-1.9 1.2-1.2 1.9-1.2-1.9-1.9-1.2z" fill="currentColor"/></svg>
                  {% when 'badge' %}
                    <svg viewBox="0 0 24 24" fill="none" focusable="false"><path d="M12 3.2l2 2.2 3-.3.8 2.9 2.7 1.4-1.4 2.6 1.4 2.7-2.7 1.4-.8 2.9-3-.3-2 2.2-2-2.2-3 .3-.8-2.9-2.7-1.4L4.9 12 3.5 9.4 6.2 8 7 5.1l3 .3z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M8.8 12.1l2 2 4.5-4.8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {% when 'family' %}
                    <svg viewBox="0 0 24 24" fill="none" focusable="false"><path d="M7 10a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm10 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm-5-1a2.3 2.3 0 1 0 0-4.6A2.3 2.3 0 0 0 12 9Z" fill="currentColor"/><path d="M4.5 19v-4.1A2.9 2.9 0 0 1 7.4 12h.4m11.7 7v-4.1a2.9 2.9 0 0 0-2.9-2.9h-.4M9 19v-5.1a3 3 0 0 1 6 0V19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                  {% else %}
                    <svg viewBox="0 0 24 24" fill="none" focusable="false"><path d="M19.5 4.5C12.7 4.8 7.1 8 5.2 13.7c-.7 2.1.7 4.4 3 4.6 6.3.5 10.7-5 11.3-13.8Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M5 19c2.6-4.3 6-7 10.4-8.4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                {% endcase %}
              {% endif %}
            </div>

            <div class="dv-promise__content">
              {% if block.settings.heading != blank %}
                <h3 class="dv-promise__item-heading">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <div class="dv-promise__item-text rte">{{ block.settings.text }}</div>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  {% render 'dv-gold-home-typography', section_anchor: section_anchor %}
  #{{ section_anchor }} {
    background: var(--dv-promise-bg);
    padding-block: 0;
  }

  #{{ section_anchor }} .dv-promise__inner {
    width: min(100% - 32px, var(--dv-promise-max-width));
    margin-inline: auto;
  }

  #{{ section_anchor }} .dv-promise__heading-wrap {
    margin: 0 0 clamp(34px, 8vw, 58px);
  }

  #{{ section_anchor }} .dv-promise__heading {
    margin: 0;
    color: var(--dv-promise-heading);
    font-family: var(--font-heading--family);
    font-size: var(--dv-section-heading-size);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .dv-promise__heading-accent {
    display: block;
    width: clamp(96px, 20vw, 156px);
    height: 7px;
    margin-top: 22px;
    border-radius: 999px;
    background: var(--dv-promise-accent);
  }

  #{{ section_anchor }} .dv-promise__intro {
    max-width: 720px;
    margin: -22px 0 38px;
    color: var(--dv-promise-muted);
    font-size: clamp(1.5rem, 3.6vw, 1.9rem);
    line-height: 1.55;
  }

  #{{ section_anchor }} .dv-promise__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 34px;
  }

  #{{ section_anchor }} .dv-promise__item {
    display: grid;
    grid-template-columns: 68px minmax(0, 1fr);
    align-items: start;
    gap: 20px;
  }

  #{{ section_anchor }} .dv-promise__icon {
    width: 68px;
    height: 68px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--dv-promise-icon-border);
    border-radius: 14px;
    background: var(--dv-promise-icon-bg);
    color: var(--dv-promise-accent);
  }

  #{{ section_anchor }} .dv-promise__icon svg {
    width: 34px;
    height: 34px;
  }

  #{{ section_anchor }} .dv-promise__icon-image {
    width: 42px;
    height: 42px;
    object-fit: contain;
  }

  #{{ section_anchor }} .dv-promise__item-heading {
    margin: 0 0 12px;
    color: var(--dv-promise-text);
    font-family: var(--font-body--family);
    font-size: clamp(2rem, 4.8vw, 2.6rem);
    font-weight: 800;
    line-height: 1.35;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .dv-promise__item-text {
    color: var(--dv-promise-muted);
    font-size: clamp(1.55rem, 3.8vw, 1.9rem);
    line-height: 1.48;
  }

  #{{ section_anchor }} .dv-promise__item-text p,
  #{{ section_anchor }} .dv-promise__intro p {
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    #{{ section_anchor }} {
      padding-block: 0;
    }

    #{{ section_anchor }} .dv-promise__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: clamp(42px, 8vw, 92px);
      row-gap: clamp(42px, 6vw, 64px);
    }

    #{{ section_anchor }} .dv-promise__item {
      grid-template-columns: 76px minmax(0, 1fr);
      gap: 22px;
    }

    #{{ section_anchor }} .dv-promise__icon {
      width: 76px;
      height: 76px;
    }
  }
</style>

{% schema %}
{
  "name": "DV Gold promise",
  "tag": "section",
  "class": "section-dv-gold-promise",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "THE DV PROMISE" },
    { "type": "richtext", "id": "text", "label": "Intro text" },
    { "type": "checkbox", "id": "show_heading_accent", "label": "Show heading accent", "default": true },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#fbf1e4" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#9b2d32" },
    { "type": "color", "id": "text_color", "label": "Subheading color", "default": "#191512" },
    { "type": "color", "id": "body_color", "label": "Body text color", "default": "#191512" },
    { "type": "color", "id": "accent_color", "label": "Accent and icon color", "default": "#c99700" },
    { "type": "color", "id": "icon_background", "label": "Icon background", "default": "#f8e8c9" },
    { "type": "color", "id": "icon_border_color", "label": "Icon border color", "default": "#e6ca8f" },
    { "type": "range", "id": "max_width", "label": "Content max width", "min": 640, "max": 1400, "step": 20, "unit": "px", "default": 1040 },
    { "type": "range", "id": "mobile_padding_top", "label": "Mobile top padding", "min": 0, "max": 180, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "mobile_padding_bottom", "label": "Mobile bottom padding", "min": 0, "max": 180, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "desktop_padding_top", "label": "Desktop top padding", "min": 0, "max": 220, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "desktop_padding_bottom", "label": "Desktop bottom padding", "min": 0, "max": 220, "step": 4, "unit": "px", "default": 84 }
  ],
  "blocks": [
    {
      "type": "promise_point",
      "name": "Promise point",
      "settings": [
        { "type": "image_picker", "id": "icon_image", "label": "Custom icon image" },
        {
          "type": "select",
          "id": "icon",
          "label": "Default icon",
          "options": [
            { "value": "leaf", "label": "Leaf" },
            { "value": "sanitized", "label": "Hygiene" },
            { "value": "badge", "label": "Quality badge" },
            { "value": "family", "label": "Family" }
          ],
          "default": "leaf"
        },
        { "type": "text", "id": "heading", "label": "Subheading", "default": "PURE & QUALITY INGREDIENTS" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Carefully sourced and selected to maintain natural quality, purity, and freshness in every pack.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DV Gold promise",
      "blocks": [
        {
          "type": "promise_point",
          "settings": {
            "icon": "leaf",
            "heading": "PURE & QUALITY INGREDIENTS",
            "text": "<p>Carefully sourced and selected to maintain natural quality, purity, and freshness in every pack.</p>"
          }
        },
        {
          "type": "promise_point",
          "settings": {
            "icon": "sanitized",
            "heading": "HYGIENICALLY PACKED",
            "text": "<p>Processed and packed under strict hygiene standards to ensure safety, cleanliness, and trust.</p>"
          }
        },
        {
          "type": "promise_point",
          "settings": {
            "icon": "badge",
            "heading": "CONSISTENT TASTE & QUALITY",
            "text": "<p>Free from unnecessary additives—only honest ingredients you can trust.</p>"
          }
        },
        {
          "type": "promise_point",
          "settings": {
            "icon": "family",
            "heading": "HEALTHIER EVERYDAY CHOICE",
            "text": "<p>Made for families who prefer safe, honest, and dependable food products for daily use.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
