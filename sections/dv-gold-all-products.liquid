{% liquid
  assign section_anchor = 'dv-gold-all-products-' | append: section.id
  assign products_collection = section.settings.collection
  assign max_products = section.settings.max_products
  assign all_link = section.settings.all_link
  if all_link == blank and products_collection != blank
    assign all_link = products_collection.url
  endif
  assign filter_link = section.settings.filter_link
  if filter_link == blank and products_collection != blank
    assign filter_link = products_collection.url
  endif
%}

<section
  id="{{ section_anchor }}"
  class="dv-all-products color-{{ section.settings.color_scheme }}"
  style="
    --dv-all-bg: {{ section.settings.background_color }};
    --dv-all-heading: {{ section.settings.heading_color }};
    --dv-all-text: {{ section.settings.text_color }};
    --dv-all-accent: {{ section.settings.accent_color }};
    --dv-all-card-bg: {{ section.settings.card_background }};
    --dv-all-image-bg: {{ section.settings.image_background }};
    --dv-all-card-width-desktop: {{ section.settings.desktop_card_width }}px;
    --dv-all-gap: {{ section.settings.card_gap }}px;
    --dv-all-max-width: {{ section.settings.max_width }}px;
    --dv-all-padding-top-mobile: {{ section.settings.mobile_padding_top }}px;
    --dv-all-padding-bottom-mobile: {{ section.settings.mobile_padding_bottom }}px;
    --dv-all-padding-top-desktop: {{ section.settings.desktop_padding_top }}px;
    --dv-all-padding-bottom-desktop: {{ section.settings.desktop_padding_bottom }}px;
    --dv-all-scroll-speed: {{ section.settings.endless_scroll_speed }};
    --dv-history-bg: {{ section.settings.history_background }};
    --dv-history-heading: {{ section.settings.history_heading_color }};
    --dv-history-text: {{ section.settings.history_text_color }};
    --dv-history-card-bg: {{ section.settings.history_card_background }};
    --dv-history-card-border: {{ section.settings.history_card_border }};
  "
>
  <div class="dv-all-products__inner">
    <div class="dv-all-products__header">
      {% if section.settings.heading != blank %}
        <h2 class="dv-all-products__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      <div class="dv-all-products__actions" aria-label="{{ section.settings.heading | escape }} navigation">
        {% if section.settings.filter_label != blank %}
          <a class="dv-all-products__action" href="{{ filter_link | default: '#' }}">{{ section.settings.filter_label }}</a>
        {% endif %}
        {% if section.settings.all_label != blank %}
          <a class="dv-all-products__action" href="{{ all_link | default: '#' }}">{{ section.settings.all_label }}</a>
        {% endif %}
      </div>
    </div>

    <div class="dv-all-products__carousel-wrap">
      <button
        type="button"
        class="dv-all-products__scroll-button dv-all-products__scroll-button--prev"
        aria-label="Scroll products left"
        data-dv-all-products-scroll-prev
      >
        <span aria-hidden="true">‹</span>
      </button>

      <div
        class="dv-all-products__carousel"
        role="list"
        aria-label="{{ section.settings.heading | escape }}"
        data-dv-all-products-track
        data-endless-scroll="{{ section.settings.enable_endless_scroll }}"
        data-scroll-speed="{{ section.settings.endless_scroll_speed }}"
      >
        {% if products_collection != blank and products_collection.products_count > 0 %}
          {% for product in products_collection.products limit: max_products %}
            {% render 'dv-gold-all-product-card',
              product: product,
              description_length: section.settings.description_length,
              show_description: section.settings.show_description,
              show_quick_add: section.settings.show_quick_add,
              is_clone: false
            %}
          {% endfor %}

        {% else %}
          {% comment %}No products are rendered until a collection with products is selected.{% endcomment %}
        {% endif %}
      </div>

      <button
        type="button"
        class="dv-all-products__scroll-button dv-all-products__scroll-button--next"
        aria-label="Scroll products right"
        data-dv-all-products-scroll-next
      >
        <span aria-hidden="true">›</span>
      </button>
    </div>
  </div>

</section>

<style>
  #{{ section_anchor }} {
    background: var(--dv-all-bg);
    color: var(--dv-all-text);
    padding-block: var(--dv-all-padding-top-mobile) var(--dv-all-padding-bottom-mobile);
    overflow: hidden;
  }

  #{{ section_anchor }} .dv-all-products__inner {
    width: min(100% - 32px, var(--dv-all-max-width));
    margin-inline: auto;
  }

  #{{ section_anchor }} .dv-all-products__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-block-end: 32px;
  }

  #{{ section_anchor }} .dv-all-products__heading {
    margin: 0;
    color: var(--dv-all-heading);
    font-family: var(--font-heading--family);
    font-size: var(--dv-section-heading-size);
    font-weight: 700;
    line-height: 0.95;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .dv-all-products__actions {
    display: flex;
    gap: 18px;
    align-items: center;
    padding-block-start: 8px;
    white-space: nowrap;
  }

  #{{ section_anchor }} .dv-all-products__action {
    color: var(--dv-all-accent);
    font-size: 1.6rem;
    line-height: 1;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  #{{ section_anchor }} .dv-all-products__carousel {
    display: flex;
    gap: var(--dv-all-gap);
    overflow-x: auto;
    overflow-y: hidden;
    padding: 1px 2px 12px;
    scroll-padding-inline: 2px;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }

  #{{ section_anchor }} .dv-all-products__carousel-wrap {
    position: relative;
  }

  #{{ section_anchor }} .dv-all-products__scroll-button {
    position: absolute;
    z-index: 2;
    top: 50%;
    display: inline-flex;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 50%;
    background: var(--dv-all-card-bg);
    color: var(--dv-all-heading);
    cursor: pointer;
    font-size: 3rem;
    line-height: 1;
    box-shadow: 0 4px 12px rgba(70, 45, 20, 0.14);
    transform: translateY(-50%);
  }

  #{{ section_anchor }} .dv-all-products__scroll-button--prev {
    left: 0;
    transform: translate(-50%, -50%);
  }

  #{{ section_anchor }} .dv-all-products__scroll-button--next {
    right: 0;
    transform: translate(50%, -50%);
  }

  #{{ section_anchor }} .dv-all-products__scroll-button:hover,
  #{{ section_anchor }} .dv-all-products__scroll-button:focus-visible {
    background: var(--dv-all-accent);
    color: #fff;
  }

  #{{ section_anchor }} .dv-all-products__scroll-button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }

  #{{ section_anchor }} .dv-all-products__scroll-button:disabled {
    cursor: not-allowed;
    opacity: 0.45;
  }

  #{{ section_anchor }} .dv-all-products__card {
    display: flex;
    flex: 0 0 min(82vw, var(--dv-all-card-width-desktop));
    flex-direction: column;
    min-height: 100%;
    background: var(--dv-all-card-bg);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 2px;
    padding: 14px 14px 15px;
    box-shadow: 0 1px 2px rgba(70, 45, 20, 0.04);
  }

  #{{ section_anchor }} .dv-all-products__image-link {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 7px;
    background: var(--dv-all-image-bg);
    color: inherit;
    text-decoration: none;
  }

  #{{ section_anchor }} .dv-all-products__image,
  #{{ section_anchor }} .dv-all-products__placeholder {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  #{{ section_anchor }} .dv-all-products__view-icon {
    position: absolute;
    z-index: 1;
    top: 6px;
    right: 6px;
    display: inline-flex;
    width: 18px;
    height: 18px;
    align-items: center;
    justify-content: center;
    color: #111827;
  }

  #{{ section_anchor }} .dv-all-products__view-icon svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  #{{ section_anchor }} .dv-all-products__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding-block-start: 20px;
  }

  #{{ section_anchor }} .dv-all-products__title {
    margin: 0 0 7px;
    color: var(--dv-all-heading);
    font-family: var(--font-heading--family);
    font-size: 1.8rem;
    font-weight: 700;
    line-height: 1.1;
  }

  #{{ section_anchor }} .dv-all-products__title a {
    color: inherit;
    text-decoration: none;
  }

  #{{ section_anchor }} .dv-all-products__description {
    margin: 0 0 18px;
    color: var(--dv-all-text);
    font-size: 1.5rem;
    line-height: 1.28;
  }

  #{{ section_anchor }} .dv-all-products__footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    margin-block-start: auto;
  }

  #{{ section_anchor }} .dv-all-products__price {
    margin: 0;
    color: var(--dv-all-heading);
    font-size: 2.1rem;
    font-weight: 800;
    line-height: 1;
  }

  #{{ section_anchor }} .dv-all-products__form {
    margin: 0;
  }

  #{{ section_anchor }} .dv-all-products__add {
    display: inline-flex;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 14px;
    background: var(--dv-all-accent);
    color: #fff;
    cursor: pointer;
    font-size: 2rem;
    line-height: 1;
    box-shadow: 0 3px 8px rgba(71, 53, 10, 0.2);
  }

  #{{ section_anchor }} .dv-all-products__add:disabled {
    cursor: not-allowed;
    opacity: 0.45;
  }

  #{{ section_anchor }} .dv-all-products__card.is-clone {
    display: none;
    pointer-events: none;
  }



  @media screen and (max-width: 749px) {
    #{{ section_anchor }} .dv-all-products__carousel {
      --dv-all-gap: clamp(12px, 4vw, 22px);
    }

    #{{ section_anchor }} .dv-all-products__card {
      flex-basis: min(78vw, 280px);
      min-width: 0;
      padding: 12px 12px 14px;
      scroll-snap-align: start;
    }

    #{{ section_anchor }} .dv-all-products__body {
      padding-block-start: 14px;
    }

    #{{ section_anchor }} .dv-all-products__title {
      margin-block-end: 6px;
      font-size: 1.6rem;
      line-height: 1.12;
    }

    #{{ section_anchor }} .dv-all-products__description {
      display: -webkit-box;
      margin-block-end: 12px;
      overflow: hidden;
      font-size: 1.35rem;
      line-height: 1.25;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    #{{ section_anchor }} .dv-all-products__price {
      font-size: 1.8rem;
    }

    #{{ section_anchor }} .dv-all-products__add {
      width: 36px;
      height: 36px;
      border-radius: 12px;
    }

    #{{ section_anchor }} .dv-all-products__scroll-button {
      width: 38px;
      height: 38px;
      font-size: 2.4rem;
    }

    #{{ section_anchor }} .dv-all-products__scroll-button--prev {
      left: 6px;
      transform: translateY(-50%);
    }

    #{{ section_anchor }} .dv-all-products__scroll-button--next {
      right: 6px;
      transform: translateY(-50%);
    }
  }

  @media screen and (min-width: 750px) {
    #{{ section_anchor }} {
      padding-block: var(--dv-all-padding-top-desktop) var(--dv-all-padding-bottom-desktop);
    }



    #{{ section_anchor }} .dv-all-products__history {
      padding-block: {{ section.settings.history_padding_top_desktop }}px {{ section.settings.history_padding_bottom_desktop }}px;
    }

    #{{ section_anchor }} .dv-all-products__history-heading {
      margin-block-end: 42px;
    }

    #{{ section_anchor }} .dv-all-products__history-content {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      align-items: center;
      gap: clamp(40px, 6vw, 92px);
    }

    #{{ section_anchor }} .dv-all-products__history-image-card {
      width: 100%;
      max-width: 600px;
      justify-self: end;
    }

    #{{ section_anchor }} .dv-all-products__history-body {
      max-width: 560px;
      text-align: left;
    }

    #{{ section_anchor }} .dv-all-products__carousel::-webkit-scrollbar {
      height: 0;
    }

    #{{ section_anchor }} .dv-all-products__card {
      flex-basis: var(--dv-all-card-width-desktop);
      scroll-snap-align: start;
    }

    @media (prefers-reduced-motion: reduce) {
      #{{ section_anchor }} .dv-all-products__features-track {
        animation: none;
      }
    }
  }
</style>



<script>
  (() => {
    const section = document.getElementById({{ section_anchor | json }});
    if (!section) return;

    const carousel = section.querySelector('[data-dv-all-products-track]');
    const previousButton = section.querySelector('[data-dv-all-products-scroll-prev]');
    const nextButton = section.querySelector('[data-dv-all-products-scroll-next]');
    if (!carousel || !previousButton || !nextButton) return;

    const getScrollAmount = () => {
      const card = carousel.querySelector('.dv-all-products__card:not(.is-clone)');
      const styles = window.getComputedStyle(carousel);
      const gap = Number.parseFloat(styles.columnGap || styles.gap) || 0;
      return card ? card.getBoundingClientRect().width + gap : carousel.clientWidth * 0.8;
    };

    const updateButtons = () => {
      const maxScrollLeft = carousel.scrollWidth - carousel.clientWidth;
      previousButton.disabled = carousel.scrollLeft <= 1;
      nextButton.disabled = carousel.scrollLeft >= maxScrollLeft - 1;
    };

    previousButton.addEventListener('click', () => {
      carousel.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    nextButton.addEventListener('click', () => {
      carousel.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });

    carousel.addEventListener('scroll', updateButtons, { passive: true });
    window.addEventListener('resize', updateButtons);
    updateButtons();
  })();
</script>

{% schema %}
{
  "name": "DV Gold all products",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "ALL PRODUCT" },
    { "type": "text", "id": "filter_label", "label": "Filter label", "default": "Filter" },
    { "type": "url", "id": "filter_link", "label": "Filter link" },
    { "type": "text", "id": "all_label", "label": "All label", "default": "All" },
    { "type": "url", "id": "all_link", "label": "All link" },
    { "type": "range", "id": "max_products", "label": "Maximum products", "min": 2, "max": 24, "step": 1, "default": 8 },
    { "type": "checkbox", "id": "show_description", "label": "Show product description", "default": true },
    { "type": "range", "id": "description_length", "label": "Description character limit", "min": 30, "max": 120, "step": 5, "default": 55 },
    { "type": "checkbox", "id": "show_quick_add", "label": "Show quick add button", "default": true },
    { "type": "checkbox", "id": "enable_endless_scroll", "label": "Enable endless desktop scroll", "default": true },
    { "type": "range", "id": "endless_scroll_speed", "label": "Endless scroll duration", "min": 10, "max": 80, "step": 5, "unit": "s", "default": 30 },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#fbf1e4" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#ffffff" },
    { "type": "color", "id": "image_background", "label": "Image background", "default": "#f7ecde" },
    { "type": "color", "id": "heading_color", "label": "Heading and price", "default": "#9b2d32" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#4d4038" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#c99700" },
    { "type": "range", "id": "desktop_card_width", "label": "Desktop card width", "min": 180, "max": 360, "step": 10, "unit": "px", "default": 240 },
    { "type": "range", "id": "card_gap", "label": "Card gap", "min": 8, "max": 48, "step": 2, "unit": "px", "default": 30 },
    { "type": "range", "id": "max_width", "label": "Content max width", "min": 900, "max": 1600, "step": 20, "unit": "px", "default": 1240 },
    { "type": "range", "id": "mobile_padding_top", "label": "Mobile padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "mobile_padding_bottom", "label": "Mobile padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "desktop_padding_top", "label": "Desktop padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "desktop_padding_bottom", "label": "Desktop padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 }
  ],
  "presets": [
    { "name": "DV Gold all products" }
  ]
}
{% endschema %}
