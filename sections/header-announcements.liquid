<script
  src="{{ 'announcement-bar.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% render 'contrast-override', background_color: section.settings.background_color, section_id: section.id %}

<div class="section-background color-custom-{{ section.id }}"></div>
<aside
  class="announcement-bar spacing-style section section--full-width color-custom-{{ section.id }}"
  style="{% render 'spacing-padding', settings: section.settings %}; --border-bottom-width: {{ section.settings.divider_width }}px;{% if section.settings.divider_color != blank %} --color-border: {{ section.settings.divider_color }};{% endif %}"
>
  <announcement-bar-component
    class="announcement-bar__slider"
    style="--announcement-speed: {{ section.settings.speed }};"
  >
    <div class="announcement-bar__track">
      <div class="announcement-bar__group">
        {% content_for 'blocks' %}
      </div>
    </div>
  </announcement-bar-component>
</aside>

{% stylesheet %}
  .announcement-bar {
    border-block-end: var(--border-bottom-width) solid var(--color-border);
  }

  .announcement-bar__slider {
    display: block;
    position: relative;
    overflow: hidden;
    width: 100%;

    @media screen and (max-width: 749px) {
      grid-column: 1 / -1;
    }
  }

  .announcement-bar__track {
    --announcement-gap: clamp(2rem, 6vw, 6rem);
    display: flex;
    width: max-content;
    column-gap: var(--announcement-gap);
    animation: announcement-marquee var(--announcement-duration, 20s) linear infinite;
    will-change: transform;
  }

  .announcement-bar__group {
    display: flex;
    flex: none;
    align-items: center;
    column-gap: var(--announcement-gap);
    width: max-content;
  }

  .announcement-bar__slide {
    flex: none;
    width: max-content;
    max-width: none;
    content-visibility: visible;
  }

  .announcement-bar__text {
    margin: 0;
    white-space: nowrap;
  }

  .announcement-bar__link {
    position: absolute;
    inset: 0;
  }

  @keyframes announcement-marquee {
    to {
      transform: translate3d(calc(-1 * var(--announcement-distance)), 0, 0);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.announcement_bar",
  "blocks": [
    {
      "type": "_announcement"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "Marquee speed",
      "min": 2,
      "max": 20,
      "step": 1,
      "default": 8,
      "info": "Higher values move the announcements faster."
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.section_width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "full-width"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "t:settings.divider_thickness",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "t:settings.divider_color",
      "placeholder": "t:settings.default",
      "visible_if": "{{ section.settings.divider_width > 0 }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "t:names.announcement_bar",
      "blocks": {
        "announcement_1": {
          "type": "_announcement"
        }
      },
      "block_order": ["announcement_1"]
    }
  ]
}
{% endschema %}
