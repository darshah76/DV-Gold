{{ 'dv-gold-mobile-collection.css' | asset_url | stylesheet_tag }}

{% liquid
  assign hero_heading = collection.metafields.custom.hero_heading.value | default: collection.metafields.custom.hero_heading
  assign hero_description = collection.metafields.custom.hero_description.value | default: collection.metafields.custom.hero_description

  if hero_heading == blank and section.settings.hero_heading_metafield != blank
    assign heading_reference = section.settings.hero_heading_metafield | split: '.'
    assign hero_heading = collection.metafields[heading_reference[0]][heading_reference[1]].value | default: collection.metafields[heading_reference[0]][heading_reference[1]]
  endif

  if hero_description == blank and section.settings.hero_description_metafield != blank
    assign description_reference = section.settings.hero_description_metafield | split: '.'
    assign hero_description = collection.metafields[description_reference[0]][description_reference[1]].value | default: collection.metafields[description_reference[0]][description_reference[1]]
  endif

  assign hero_heading = hero_heading | default: 'Premium Tea Collection'
  assign hero_description = hero_description | default: 'Discover aromatic blends crafted for everyday freshness, purity, and consistent taste.'
%}

<div class="dv-mobile-collection">
  <header class="dv-mobile-collection__header" aria-label="Mobile collection header">
    <button class="dv-mobile-collection__icon-button" type="button" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>

    <a class="dv-mobile-collection__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }} home">
      {% if settings.logo != blank %}
        {{
          settings.logo
          | image_url: width: 180
          | image_tag: loading: 'eager', widths: '90, 120, 180', sizes: '90px', alt: shop.name
        }}
      {% else %}
        <span>{{ shop.name }}</span>
      {% endif %}
    </a>

    <nav class="dv-mobile-collection__actions" aria-label="Collection actions">
      <a class="dv-mobile-collection__icon-link" href="{{ routes.search_url }}" aria-label="Search">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m20.5 19.1-4.7-4.7a7.3 7.3 0 1 0-1.4 1.4l4.7 4.7 1.4-1.4ZM5.7 10.2a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0Z"/></svg>
      </a>
      <a class="dv-mobile-collection__icon-link" href="{{ routes.cart_url }}" aria-label="Cart">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 7V6a5 5 0 0 1 10 0v1h2.2l1 14H3.8l1-14H7Zm2 0h6V6a3 3 0 0 0-6 0v1Zm-2.3 2-.7 10h12l-.7-10H17v2h-2V9H9v2H7V9h-.3Z"/></svg>
      </a>
    </nav>
  </header>

  <main class="dv-mobile-collection__main" id="MainContent">
    <section class="dv-mobile-collection__hero" aria-labelledby="MobileCollectionHeroTitle">
      <p class="dv-mobile-collection__eyebrow">DV GOLD COLLECTION</p>
      <h1 id="MobileCollectionHeroTitle">{{ hero_heading }}</h1>
      <p class="dv-mobile-collection__description">{{ hero_description }}</p>
      <a class="dv-mobile-collection__button" href="#MobileCollectionProducts">Shop Bestsellers</a>
    </section>

    <div class="dv-mobile-collection__toolbar" aria-label="Collection filters and sorting">
      <button class="dv-mobile-collection__toolbar-button" type="button">Filter</button>
      <form class="dv-mobile-collection__sort" method="get">
        <label for="MobileCollectionSort">Sort</label>
        <select id="MobileCollectionSort" name="sort_by" onchange="this.form.submit()">
          {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
          {% for option in collection.sort_options %}
            <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>{{ option.name }}</option>
          {% endfor %}
        </select>
      </form>
    </div>

    <section id="MobileCollectionProducts" class="dv-mobile-collection__products" aria-labelledby="MobileCollectionProductsTitle">
      <h2 id="MobileCollectionProductsTitle">Curated Selection</h2>
      {% paginate collection.products by section.settings.products_per_page %}
        <ul class="dv-mobile-collection__grid" role="list">
          {% for product in collection.products %}
            <li>
              {% render 'dv-gold-mobile-product-card', product: product %}
            </li>
          {% else %}
            <li class="dv-mobile-collection__empty">No products found in this collection.</li>
          {% endfor %}
        </ul>
        {% if paginate.pages > 1 %}
          <div class="dv-mobile-collection__pagination">{{ paginate | default_pagination }}</div>
        {% endif %}
      {% endpaginate %}
    </section>
  </main>
</div>

{% schema %}
{
  "name": "Mobile collection",
  "settings": [
    {
      "type": "paragraph",
      "content": "Create collection metafields for custom.hero_heading and custom.hero_description so every collection can provide unique hero copy in the theme editor. Empty metafields use the built-in fallback text."
    },
    {
      "type": "text",
      "id": "hero_heading_metafield",
      "label": "Collection hero heading metafield",
      "default": "custom.hero_heading"
    },
    {
      "type": "text",
      "id": "hero_description_metafield",
      "label": "Collection hero description metafield",
      "default": "custom.hero_description"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    }
  ]
}
{% endschema %}
