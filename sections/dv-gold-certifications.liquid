{% liquid
  assign section_anchor = 'dv-gold-certifications-' | append: section.id
%}

<section
  id="{{ section_anchor }}"
  class="dv-certifications color-{{ section.settings.color_scheme }}"
  style="
    --dv-certifications-page-bg: {{ section.settings.page_background }};
    --dv-certifications-card-bg: {{ section.settings.card_background }};
    --dv-certifications-card-border: {{ section.settings.card_border_color }};
    --dv-certifications-heading: {{ section.settings.heading_color }};
    --dv-certifications-heading-desktop-size: {{ section.settings.heading_desktop_size }}px;
    --dv-certifications-heading-mobile-size: {{ section.settings.heading_mobile_size }}px;
    --dv-certifications-heading-letter-spacing: {{ section.settings.heading_letter_spacing | divided_by: 100.0 }}em;
    --dv-certifications-heading-max-width: {{ section.settings.heading_max_width }}px;
    --dv-certifications-heading-transform: {{ section.settings.heading_transform }};
    --dv-certifications-text: {{ section.settings.text_color }};
    --dv-certifications-icon-bg: {{ section.settings.icon_background }};
    --dv-certifications-icon-shadow: {{ section.settings.icon_shadow_color }};
    --dv-certifications-placeholder: {{ section.settings.placeholder_color }};
    --dv-certifications-max-width: {{ section.settings.max_width }}px;
    --dv-certifications-badge-size: {{ section.settings.badge_size }}px;
    --dv-certifications-badge-icon-size: {{ section.settings.badge_icon_size }}px;
    --dv-certifications-badge-gap: {{ section.settings.badge_gap }}px;
    --dv-certifications-badge-border-radius: {{ section.settings.badge_border_radius }}px;
    --dv-certifications-badge-shadow-x: {{ section.settings.badge_shadow_x }}px;
    --dv-certifications-badge-shadow-y: {{ section.settings.badge_shadow_y }}px;
    --dv-certifications-badge-shadow-blur: {{ section.settings.badge_shadow_blur }}px;
    --dv-certifications-mobile-padding-top: {{ section.settings.mobile_padding_top }}px;
    --dv-certifications-mobile-padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    --dv-certifications-desktop-padding-top: {{ section.settings.desktop_padding_top }}px;
    --dv-certifications-desktop-padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
    --dv-certifications-card-mobile-padding-y: {{ section.settings.card_mobile_padding_y }}px;
    --dv-certifications-card-mobile-padding-x: {{ section.settings.card_mobile_padding_x }}px;
    --dv-certifications-card-desktop-padding-y: {{ section.settings.card_desktop_padding_y }}px;
    --dv-certifications-card-desktop-padding-x: {{ section.settings.card_desktop_padding_x }}px;
    --dv-certifications-card-border-radius: {{ section.settings.card_border_radius }}px;
  "
>
  <div class="dv-certifications__panel">
    {% if section.settings.heading != blank %}
      <h2 class="dv-certifications__heading">{{ section.settings.heading | escape | newline_to_br }}</h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="dv-certifications__badges" role="list">
        {% for block in section.blocks %}
          <div class="dv-certifications__badge-card" role="listitem" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {% liquid
                assign image_alt = block.settings.image.alt | default: block.settings.alt_text
              %}
              {{
                block.settings.image
                | image_url: width: 180
                | image_tag:
                  loading: 'lazy',
                  widths: '64, 96, 128, 180',
                  sizes: '(min-width: 750px) 96px, 64px',
                  class: 'dv-certifications__badge-image',
                  alt: image_alt
              }}
            {% else %}
              <span class="dv-certifications__placeholder" aria-hidden="true">
                <span>{{ block.settings.placeholder_text | escape }}</span>
              </span>
              <span class="visually-hidden">{{ block.settings.alt_text | escape }}</span>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.text != blank %}
      <div class="dv-certifications__text rte">{{ section.settings.text }}</div>
    {% endif %}
  </div>
</section>

<style>
  #{{ section_anchor }} {
    background: var(--dv-certifications-page-bg);
    padding-block: var(--dv-certifications-mobile-padding-top) var(--dv-certifications-mobile-padding-bottom);
    padding-inline: 30px;
  }

  #{{ section_anchor }} .dv-certifications__panel {
    width: min(100%, var(--dv-certifications-max-width));
    margin-inline: auto;
    padding: var(--dv-certifications-card-mobile-padding-y) var(--dv-certifications-card-mobile-padding-x);
    border: 1px solid var(--dv-certifications-card-border);
    border-radius: var(--dv-certifications-card-border-radius);
    background: var(--dv-certifications-card-bg);
  }

  #{{ section_anchor }} .dv-certifications__heading {
    max-width: min(100%, var(--dv-certifications-heading-max-width));
    margin: 0;
    margin-inline: auto;
    color: var(--dv-certifications-heading);
    font-family: var(--font-heading--family);
    font-size: clamp(3rem, 9vw, var(--dv-certifications-heading-mobile-size));
    font-weight: 800;
    line-height: 1.33;
    letter-spacing: min(var(--dv-certifications-heading-letter-spacing), 0.04em);
    overflow-wrap: anywhere;
    text-align: center;
    text-transform: var(--dv-certifications-heading-transform);
    word-break: normal;
    hyphens: manual;
    text-wrap: balance;
  }

  #{{ section_anchor }} .dv-certifications__badges {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--dv-certifications-badge-gap);
    margin-block: 58px 55px;
  }

  #{{ section_anchor }} .dv-certifications__badge-card {
    display: inline-flex;
    width: var(--dv-certifications-badge-size);
    height: var(--dv-certifications-badge-size);
    align-items: center;
    justify-content: center;
    border-radius: var(--dv-certifications-badge-border-radius);
    background: var(--dv-certifications-icon-bg);
    box-shadow: var(--dv-certifications-badge-shadow-x) var(--dv-certifications-badge-shadow-y) var(--dv-certifications-badge-shadow-blur) var(--dv-certifications-icon-shadow);
  }

  #{{ section_anchor }} .dv-certifications__badge-image {
    display: block;
    width: var(--dv-certifications-badge-icon-size);
    height: var(--dv-certifications-badge-icon-size);
    object-fit: contain;
  }

  #{{ section_anchor }} .dv-certifications__placeholder {
    display: inline-flex;
    width: var(--dv-certifications-badge-icon-size);
    height: var(--dv-certifications-badge-icon-size);
    align-items: center;
    justify-content: center;
    border: 2px solid var(--dv-certifications-placeholder);
    border-radius: 50%;
    color: var(--dv-certifications-placeholder);
    font-size: 1rem;
    font-weight: 800;
    line-height: 1;
    text-align: center;
    text-transform: uppercase;
  }

  #{{ section_anchor }} .dv-certifications__text {
    max-width: 310px;
    margin-inline: auto;
    color: var(--dv-certifications-text);
    font-size: 1.6rem;
    line-height: 1.75;
    text-align: center;
  }

  #{{ section_anchor }} .dv-certifications__text p {
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    #{{ section_anchor }} {
      padding-block: var(--dv-certifications-desktop-padding-top) var(--dv-certifications-desktop-padding-bottom);
      padding-inline: 48px;
    }

    #{{ section_anchor }} .dv-certifications__panel {
      padding: var(--dv-certifications-card-desktop-padding-y) var(--dv-certifications-card-desktop-padding-x);
      border-radius: var(--dv-certifications-card-border-radius);
    }

    #{{ section_anchor }} .dv-certifications__heading {
      font-size: clamp(var(--dv-certifications-heading-mobile-size), 5.4vw, var(--dv-certifications-heading-desktop-size));
      line-height: 1.18;
    }

    #{{ section_anchor }} .dv-certifications__text {
      max-width: 680px;
      font-size: clamp(1.8rem, 2vw, 2.2rem);
      line-height: 1.65;
    }
  }

  @media screen and (min-width: 990px) {
    #{{ section_anchor }} .dv-certifications__badges {
      flex-direction: row;
      justify-content: center;
      gap: var(--dv-certifications-badge-gap);
      margin-block: clamp(52px, 7vw, 78px) clamp(48px, 6vw, 68px);
    }

  }
</style>

{% schema %}
{
  "name": "DV Gold certifications",
  "tag": "section",
  "class": "section-dv-gold-certifications",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "CERTIFICATIONS\n& REGISTRATIONS" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Every product undergoes rigorous quality checks to ensure it meets our high standards. From sourcing to packaging, we maintain consistency, safety, and excellence at every step.</p>" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "color", "id": "page_background", "label": "Page background", "default": "#fbf5ef" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#fbf1e4" },
    { "type": "color", "id": "card_border_color", "label": "Card border", "default": "#f0dfbf" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#9b2d32" },
    { "type": "range", "id": "heading_desktop_size", "label": "Heading desktop size", "min": 32, "max": 96, "step": 1, "unit": "px", "default": 68 },
    { "type": "range", "id": "heading_mobile_size", "label": "Heading mobile size", "min": 24, "max": 64, "step": 1, "unit": "px", "default": 44 },
    { "type": "range", "id": "heading_letter_spacing", "label": "Heading letter spacing", "min": 0, "max": 12, "step": 1, "unit": "%", "default": 4 },
    { "type": "range", "id": "heading_max_width", "label": "Heading max width", "min": 280, "max": 1000, "step": 10, "unit": "px", "default": 720 },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading text transform",
      "default": "uppercase",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" }
      ]
    },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#000000" },
    { "type": "color", "id": "icon_background", "label": "Badge background", "default": "#ffffff" },
    { "type": "color", "id": "icon_shadow_color", "label": "Badge shadow", "default": "#eadfce" },
    { "type": "color", "id": "placeholder_color", "label": "Placeholder color", "default": "#9b2d32" },
    { "type": "range", "id": "max_width", "label": "Content max width", "min": 360, "max": 1180, "step": 20, "unit": "px", "default": 860 },
    { "type": "range", "id": "badge_size", "label": "Badge size", "min": 40, "max": 160, "step": 2, "unit": "px", "default": 83 },
    { "type": "range", "id": "badge_icon_size", "label": "Badge icon size", "min": 24, "max": 120, "step": 2, "unit": "px", "default": 56 },
    { "type": "range", "id": "badge_gap", "label": "Badge gap", "min": 0, "max": 120, "step": 2, "unit": "px", "default": 26 },
    { "type": "range", "id": "badge_border_radius", "label": "Badge border radius", "min": 0, "max": 80, "step": 1, "unit": "px", "default": 12 },
    { "type": "range", "id": "badge_shadow_x", "label": "Badge shadow horizontal offset", "min": -20, "max": 20, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "badge_shadow_y", "label": "Badge shadow vertical offset", "min": -20, "max": 20, "step": 1, "unit": "px", "default": 2 },
    { "type": "range", "id": "badge_shadow_blur", "label": "Badge shadow blur", "min": 0, "max": 40, "step": 1, "unit": "px", "default": 3 },
    { "type": "range", "id": "mobile_padding_top", "label": "Mobile top padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 44 },
    { "type": "range", "id": "mobile_padding_bottom", "label": "Mobile bottom padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "desktop_padding_top", "label": "Desktop top padding", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "desktop_padding_bottom", "label": "Desktop bottom padding", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 72 }
  ],
  "blocks": [
    {
      "type": "certification",
      "name": "Certification",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Logo image" },
        { "type": "text", "id": "placeholder_text", "label": "Placeholder text", "default": "ISO" },
        { "type": "text", "id": "alt_text", "label": "Alt text", "default": "Certification logo" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DV Gold certifications",
      "blocks": [
        { "type": "certification", "settings": { "placeholder_text": "ISO", "alt_text": "ISO certification logo" } },
        { "type": "certification", "settings": { "placeholder_text": "FSSAI", "alt_text": "FSSAI registration logo" } },
        { "type": "certification", "settings": { "placeholder_text": "GMP", "alt_text": "GMP certification logo" } }
      ]
    }
  ]
}
{% endschema %}
